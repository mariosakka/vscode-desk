<fezzan-page title="DDD Part 4–6 — Reguli &amp; Tooling">
  <style>
    /* ═══════════════════════════════════════════════
       Study guide — shared base styles (fezzan port)
       Sidebar + body-flex layout removed; theme is fixed
       to the dark palette (no JS theme toggle in fezzan).
       ═══════════════════════════════════════════════ */
    
    :root {
      --bg: #0f1117;
      --surface: #1a1d27;
      --surface2: #22263a;
      --border: #2e3250;
      --accent: #7c6af7;
      --accent2: #5eead4;
      --text: #e2e8f0;
      --muted: #8892a4;
      --code-bg: #12141f;
      --tag-domain: #7c6af7;
      --tag-app: #5eead4;
      --tag-infra: #f59e0b;
      --tag-warn: #ef4444;
      --radius: 10px;
      --font-code: 'JetBrains Mono', 'Fira Code', 'Cascadia Code', monospace;
    }
    
    /* ── Main column (centered, no sidebar) ── */
    main {
      max-width: 900px;
      margin: 0 auto;
      padding: 24px 32px 96px;
      background: var(--bg);
      color: var(--text);
      font-family: 'Inter', 'Segoe UI', system-ui, sans-serif;
      font-size: 15px;
      line-height: 1.7;
    }
    
    /* ── Page header ── */
    .page-header {
      margin-bottom: 48px;
      padding-bottom: 32px;
      border-bottom: 1px solid var(--border);
    }
    .eyebrow {
      font-size: 11px;
      letter-spacing: .1em;
      text-transform: uppercase;
      color: var(--accent);
      margin-bottom: 10px;
      font-weight: 700;
    }
    .page-header h1 {
      font-size: 30px;
      font-weight: 700;
      line-height: 1.2;
      margin-bottom: 14px;
    }
    .page-header p { color: var(--muted); max-width: 620px; margin-bottom: 0; }
    
    /* ── Badges ── */
    .badge {
      display: inline-block;
      padding: 2px 9px;
      border-radius: 20px;
      font-size: 11px;
      font-weight: 700;
      letter-spacing: .04em;
      margin-right: 5px;
    }
    .bd-domain  { background: rgba(124,106,247,.16); color: var(--tag-domain); }
    .bd-app     { background: rgba(94,234,212,.14);  color: var(--tag-app); }
    .bd-infra   { background: rgba(245,158,11,.14);  color: var(--tag-infra); }
    .bd-warn    { background: rgba(239,68,68,.14);   color: var(--tag-warn); }
    .bd-ok      { background: rgba(34,197,94,.14);   color: #22c55e; }
    
    /* ── Section ── */
    .section { margin-bottom: 60px; scroll-margin-top: 24px; }
    
    h2.section-title {
      font-size: 20px;
      font-weight: 700;
      margin-bottom: 18px;
      display: flex;
      align-items: center;
      gap: 10px;
    }
    h2.section-title .icon {
      width: 30px; height: 30px;
      background: var(--surface2);
      border: 1px solid var(--border);
      border-radius: 7px;
      display: inline-flex;
      align-items: center;
      justify-content: center;
      font-size: 14px;
      flex-shrink: 0;
    }
    
    h3.sub { font-size: 14px; font-weight: 700; color: var(--accent2); text-transform: uppercase; letter-spacing: .08em; margin: 28px 0 12px; }
    
    p { color: var(--muted); margin-bottom: 12px; }
    p strong, li strong { color: var(--text); }
    ul, ol { padding-left: 20px; color: var(--muted); margin-bottom: 12px; }
    li { margin-bottom: 4px; }
    
    /* ── Cards ── */
    .card {
      background: var(--surface);
      border: 1px solid var(--border);
      border-radius: var(--radius);
      padding: 18px 22px;
      margin-bottom: 14px;
    }
    .card-title { font-size: 13px; font-weight: 700; color: var(--text); margin-bottom: 6px; }
    .card p { margin: 0; font-size: 13.5px; }
    
    /* ── Callouts ── */
    .callout {
      border-left: 3px solid var(--accent);
      background: rgba(124,106,247,.07);
      border-radius: 0 var(--radius) var(--radius) 0;
      padding: 13px 17px;
      margin: 14px 0;
      font-size: 13.5px;
      color: var(--muted);
    }
    .callout strong { color: var(--text); }
    .callout.tip  { border-color: var(--accent2); background: rgba(94,234,212,.06); }
    .callout.warn { border-color: var(--tag-warn); background: rgba(239,68,68,.06); }
    .callout.ok   { border-color: #22c55e; background: rgba(34,197,94,.06); }
    .callout.infra{ border-color: var(--tag-infra); background: rgba(245,158,11,.06); }
    
    /* ── Code blocks ── */
    .code-block {
      background: var(--code-bg);
      border: 1px solid var(--border);
      border-radius: var(--radius);
      margin: 14px 0;
      overflow: hidden;
    }
    .code-header {
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding: 9px 15px;
      border-bottom: 1px solid var(--border);
      background: var(--surface2);
      gap: 8px;
    }
    .code-lang { font-size: 10px; font-weight: 700; color: var(--accent); text-transform: uppercase; letter-spacing: .08em; flex-shrink: 0; }
    .code-file { font-size: 11px; color: var(--muted); font-family: var(--font-code); overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
    .copy-btn {
      background: none;
      border: 1px solid var(--border);
      border-radius: 5px;
      color: var(--muted);
      font-size: 11px;
      padding: 2px 9px;
      cursor: pointer;
      transition: all .15s;
      flex-shrink: 0;
    }
    .copy-btn:hover { color: var(--text); border-color: var(--accent); }
    .copy-btn.copied { color: var(--accent2); border-color: var(--accent2); }
    
    pre {
      padding: 16px 18px;
      overflow-x: auto;
      font-family: var(--font-code);
      font-size: 12.5px;
      line-height: 1.65;
      color: var(--text);
      scrollbar-width: thin;
      scrollbar-color: var(--border) transparent;
    }
    code { font-family: var(--font-code); }
    
    .ic {
      background: var(--code-bg);
      border: 1px solid var(--border);
      border-radius: 4px;
      padding: 1px 6px;
      font-family: var(--font-code);
      font-size: 12px;
      color: var(--accent2);
    }
    
    /* Syntax colours — dark */
    .kw   { color: #c792ea; }
    .fn   { color: #82aaff; }
    .str  { color: #c3e88d; }
    .num  { color: #f78c6c; }
    .cmt  { color: #546e7a; font-style: italic; }
    .ty   { color: #ffcb6b; }
    .prop { color: #89ddff; }
    .dec  { color: #ff5370; }
    
    /* ── Tables ── */
    table { width: 100%; border-collapse: collapse; margin: 14px 0; font-size: 13.5px; }
    th {
      background: var(--surface2);
      color: var(--muted);
      text-align: left;
      padding: 9px 13px;
      font-size: 10.5px;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: .06em;
      border-bottom: 1px solid var(--border);
    }
    td {
      padding: 10px 13px;
      border-bottom: 1px solid var(--border);
      color: var(--text);
      vertical-align: top;
    }
    tr:last-child td { border-bottom: none; }
    tr:hover td { background: rgba(255,255,255,.015); }
    td.mono { font-family: var(--font-code); font-size: 12px; color: var(--accent2); white-space: nowrap; }
    td.center { text-align: center; }
    
    /* ── Flow / step diagrams ── */
    .flow {
      background: var(--surface);
      border: 1px solid var(--border);
      border-radius: var(--radius);
      padding: 20px 22px;
      margin: 14px 0 20px;
    }
    .flow-step {
      display: flex;
      align-items: flex-start;
      gap: 13px;
      padding: 9px 0;
      border-bottom: 1px solid var(--border);
    }
    .flow-step:last-child { border-bottom: none; }
    .flow-num {
      width: 24px; height: 24px;
      background: var(--accent);
      color: #fff;
      border-radius: 50%;
      display: flex; align-items: center; justify-content: center;
      font-size: 10px; font-weight: 700;
      flex-shrink: 0; margin-top: 3px;
    }
    .flow-num.ret  { background: var(--accent2); color: var(--bg); }
    .flow-num.warn { background: var(--tag-warn); }
    .flow-num.infra{ background: var(--tag-infra); color: #0f1117; }
    .flow-content { flex: 1; min-width: 0; }
    .flow-label { font-size: 13px; color: var(--text); font-weight: 500; flex-wrap: wrap; }
    .flow-detail { font-size: 12px; color: var(--muted); margin-top: 3px; }
    .arr { color: var(--muted); margin: 0 4px; font-size: 11px; }
    
    /* ── Layer diagram ── */
    .layer-diagram { display: flex; flex-direction: column; gap: 4px; margin: 16px 0; }
    .layer {
      border-radius: 8px;
      padding: 12px 18px;
      display: flex;
      align-items: center;
      gap: 12px;
      font-size: 13px;
    }
    .layer.l-infra  { background: rgba(245,158,11,.1); border: 1px solid rgba(245,158,11,.3); }
    .layer.l-app    { background: rgba(94,234,212,.08); border: 1px solid rgba(94,234,212,.25); }
    .layer.l-domain { background: rgba(124,106,247,.1); border: 1px solid rgba(124,106,247,.3); }
    .layer .layer-name { font-weight: 700; font-size: 12px; min-width: 90px; }
    .layer.l-infra  .layer-name { color: var(--tag-infra); }
    .layer.l-app    .layer-name { color: var(--tag-app); }
    .layer.l-domain .layer-name { color: var(--tag-domain); }
    .layer .layer-items { color: var(--muted); font-size: 12.5px; }
    .layer .dep-arrow { margin-left: auto; font-size: 11px; color: var(--muted); white-space: nowrap; }
    
    /* ── Checklist ── */
    .checklist { list-style: none; margin: 14px 0; }
    .checklist li {
      display: flex;
      gap: 11px;
      padding: 9px 0;
      border-bottom: 1px solid var(--border);
      align-items: flex-start;
      font-size: 13.5px;
      color: var(--muted);
    }
    .checklist li:last-child { border-bottom: none; }
    .check-num {
      width: 22px; height: 22px;
      background: var(--surface2);
      border: 1px solid var(--border);
      border-radius: 50%;
      display: flex; align-items: center; justify-content: center;
      font-size: 10px; font-weight: 700;
      color: var(--accent);
      flex-shrink: 0; margin-top: 2px;
    }
    .checklist li strong { color: var(--text); }
    
    /* ── Collapsible ── */
    details {
      border: 1px solid var(--border);
      border-radius: var(--radius);
      margin-bottom: 10px;
      overflow: hidden;
    }
    summary {
      padding: 13px 17px;
      cursor: pointer;
      font-size: 13.5px;
      font-weight: 600;
      color: var(--text);
      background: var(--surface);
      list-style: none;
      display: flex;
      align-items: center;
      justify-content: space-between;
      user-select: none;
    }
    summary::-webkit-details-marker { display: none; }
    summary::after { content: '▸'; color: var(--muted); font-size: 11px; }
    details[open] summary::after { content: '▾'; }
    details[open] summary { border-bottom: 1px solid var(--border); }
    .details-body { padding: 16px 18px; background: var(--code-bg); }
    
    /* ── Rule pill ── */
    .rule {
      display: inline-block;
      font-family: var(--font-code);
      font-size: 10.5px;
      font-weight: 700;
      padding: 1px 7px;
      border-radius: 4px;
      margin: 0 2px;
    }
    .rule.err  { background: rgba(239,68,68,.14); color: var(--tag-warn); border: 1px solid rgba(239,68,68,.3); }
    .rule.warn { background: rgba(245,158,11,.14); color: var(--tag-infra); border: 1px solid rgba(245,158,11,.3); }
    .rule.ok   { background: rgba(34,197,94,.12); color: #22c55e; border: 1px solid rgba(34,197,94,.25); }
    
    /* ── Scrollbar ── */
    ::-webkit-scrollbar { width: 6px; height: 6px; }
    ::-webkit-scrollbar-track { background: transparent; }
    ::-webkit-scrollbar-thumb { background: var(--border); border-radius: 3px; }
  </style>

  <div class="page-header">
    <div class="eyebrow">Part 4–6</div>
    <h1>House style, tipuri & tooling</h1>
    <p>Cum specializăm textbook-ul DDD în acest repo: regulile concrete, convențiile de naming, granița OpenAPI și cum e verificată automat conformitatea.</p>
  </div>

  <!-- ══════════════════════════════════════════
       PART 4 — HOUSE STYLE
  ══════════════════════════════════════════ -->

  <div class="section" id="e1">
    <h2 class="section-title"><span class="icon">🚦</span>4.1 Erori ca valori — <span class="rule err">E1</span> / D9 (<code class="ic">neverthrow</code>)</h2>
    <p>Nu folosim <code class="ic">throw</code> pentru eșecuri așteptate. Repository-uri, use case-uri, metode de domain și mapperi returnează <code class="ic">Result&lt;T, E&gt;</code> (sincron) sau <code class="ic">ResultAsync&lt;T, E&gt;</code> (async). Tipul de eroare face <strong>parte din semnătură</strong> — compilatorul îi forțează pe apelatori să îl trateze. Compui cu <code class="ic">.andThen()</code> / <code class="ic">.map()</code> / <code class="ic">.orElse()</code> ("railway-oriented programming"). Adaptorii de infra pot <code class="ic">catch</code> o eroare aruncată de ORM/lib <em>la graniță</em> și o mapează într-un <code class="ic">Result</code>.</p>

    <div class="code-block">
      <div class="code-header"><span class="code-lang">TypeScript</span><span class="code-file">Railway — lanț de operații fără try/catch</span></div>
      <pre><code><span class="cmt">// Ok → andThen → andThen → map = succes</span>
<span class="cmt">// oricare Err → scurtcircuitează și ajunge direct la subscriber</span>
repo.<span class="fn">findById</span>(id)
  .<span class="fn">andThen</span>((entity) => entity.<span class="fn">approve</span>())          <span class="cmt">// Result&lt;void, TransitionError&gt;</span>
  .<span class="fn">andThen</span>(() => repo.<span class="fn">save</span>(entity))               <span class="cmt">// ResultAsync&lt;void, PersistenceError&gt;</span>
  .<span class="fn">map</span>(() => ({ success: <span class="kw">true</span> }));                <span class="cmt">// transformă Ok-ul final</span></code></pre>
    </div>

    <div class="callout warn">
      <strong>Excepție / datorie tehnicăcunoscută:</strong> <code class="ic">shared/domain/value_objects/money.value_object.ts</code> încă aruncă excepții și literalmente începe cu <code class="ic">// TODO Implement neverthrow</code>. Tratează-l ca excepție, nu ca model.
    </div>
  </div>

  <div class="section" id="d11">
    <h2 class="section-title"><span class="icon">🏭</span>4.2 Fără base classes; ctor privat + factory — <span class="rule ok">D11</span></h2>
    <p>Nu există nicio clasă de bază <code class="ic">Entity</code> / <code class="ic">AggregateRoot</code> / <code class="ic">ValueObject</code> de extins. În schimb:</p>
    <ul>
      <li><code class="ic">private constructor(private props: Props)</code></li>
      <li><code class="ic">static create(...)</code> — cerere nouă, validată</li>
      <li><code class="ic">static fromPrimitive(...)</code> — rehidratare din DB</li>
      <li><code class="ic">toPrimitive()</code> — dump pentru persistență</li>
      <li>Getterele returnează <strong>copii defensive</strong> (ex. <code class="ic">get tags() &#123; return [...this.props.tags]; &#125;</code>)</li>
    </ul>
    <div class="card">
      <div class="card-title">Model ✅ vs. Counter-example ❌</div>
      <p><code class="ic">feature_request/domain/entities/feature_request.entity.ts</code> — model corect (ctor privat + factories).<br/>
      <code class="ic">payments</code> — <code class="ic">PaymentMethod</code> cu ctor public + getteri este counter-example-ul D11.</p>
    </div>
  </div>

  <div class="section" id="enums">
    <h2 class="section-title"><span class="icon">🏷️</span>4.3 Fără TypeScript <code class="ic">enum</code> — obiecte <code class="ic">as const</code></h2>
    <p>Per convenția TS din repo (vezi <code class="ic">CLAUDE.md</code>), enum-urile de domain sunt obiecte <code class="ic">as const</code> cu un union type extras + un type-guard:</p>

    <div class="code-block">
      <div class="code-header"><span class="code-lang">TypeScript</span><span class="code-file">domain/enums/feature_request_status.enum.ts</span></div>
      <pre><code><span class="kw">const</span> <span class="ty">FeatureRequestStatus</span> = {
  Approved: <span class="str">"approved"</span>,
  Pending:  <span class="str">"pending"</span>,
  Planned:  <span class="str">"planned"</span>,
  Dev:      <span class="str">"dev"</span>,
  Done:     <span class="str">"done"</span>,
  Rejected: <span class="str">"rejected"</span>,
} <span class="kw">as const</span>;

<span class="kw">type</span> <span class="ty">FeatureRequestStatusType</span> =
  <span class="kw">typeof</span> <span class="ty">FeatureRequestStatus</span>[<span class="kw">keyof typeof</span> <span class="ty">FeatureRequestStatus</span>];

<span class="kw">function</span> <span class="fn">isFeatureRequestStatus</span>(v: <span class="ty">unknown</span>): v <span class="kw">is</span> <span class="ty">FeatureRequestStatusType</span> {
  <span class="kw">return</span> <span class="ty">Object</span>.<span class="fn">values</span>(<span class="ty">FeatureRequestStatus</span>).<span class="fn">includes</span>(v <span class="kw">as</span> <span class="ty">any</span>);
}</code></pre>
    </div>
  </div>

  <div class="section" id="di">
    <h2 class="section-title"><span class="icon">💉</span>4.4 DI cu tsyringe — <span class="rule err">DI1</span>–<span class="rule err">DI4</span>, D7, <span class="rule err">D8</span></h2>

    <table>
      <thead><tr><th>Regulă</th><th>Severitate</th><th>Ce spune</th></tr></thead>
      <tbody>
        <tr>
          <td><span class="rule err">DI3</span></td><td><span class="rule err">ERROR</span></td>
          <td>Interfețe/porturi/contracte se bind prin <strong>string token</strong> (<code class="ic">@inject("IFeatureRequestRepository")</code>); clase concrete use case/controller se auto-bind (<code class="ic">@inject(ToggleVoteUseCase)</code>).</td>
        </tr>
        <tr>
          <td><span class="rule err">DI1</span></td><td><span class="rule err">ERROR</span></td>
          <td>Fiecare token folosit în <code class="ic">@inject</code>/<code class="ic">@injectAll</code> trebuie înregistrat în vreun <code class="ic">di.config.ts</code> încărcat. <code class="ic">@injectAll("IApiErrorMapper")</code> colectează deliberat mapper-ul fiecărui modul.</td>
        </tr>
        <tr>
          <td><span class="rule err">DI4</span></td><td><span class="rule err">ERROR</span></td>
          <td>Registration reachability — cel mai fragil invariant (vezi §2.4).</td>
        </tr>
        <tr>
          <td><span class="rule warn">DI2</span></td><td><span class="rule warn">WARN</span></td>
          <td>Token-urile ar trebui să vină dintr-un <code class="ic">tokens.ts</code> per modul (<code class="ic">as const</code>). <strong>Neadoptat încă</strong> — toate modulele folosesc string literals goale.</td>
        </tr>
        <tr>
          <td><span class="rule err">D8</span></td><td><span class="rule err">ERROR</span></td>
          <td><strong>Domain-ul e fără framework — fără <code class="ic">@injectable</code></strong> acolo. Un domain service curat e o clasă stateless simplă. <strong>Violări curente</strong> (urmărite în baseline): domain services din <code class="ic">payments</code> și <code class="ic">authority_search</code> poartă <code class="ic">@injectable</code>.</td>
        </tr>
      </tbody>
    </table>
  </div>

  <div class="section" id="ports">
    <h2 class="section-title"><span class="icon">🔌</span>4.5 Ports & Adapters în loc de Domain Events — <span class="rule ok">D3</span>/<span class="rule ok">D4</span></h2>
    <p>Nu există un bus de domain events. Efectele secundare (notifică adminii, emailează creatorul) sunt <strong>porturi de aplicație</strong> (<code class="ic">IFeatureRequestNotifier</code>) implementate de <strong>adaptori de infra</strong> (<code class="ic">EmailFeatureRequestNotifierAdapter</code>) și apelate explicit în use case. Mai simplu, sincron, trivial de testat cu un fake.</p>

    <div class="card">
      <div class="card-title">Ownership-ul portului (D3/D4) — un singur principiu</div>
      <p>Un port trăiește în layer-ul care declară nevoia:<br/>
      • Porturi de persistență → <code class="ic">domain/repository_interfaces/</code> (D4)<br/>
      • Porturi outbound non-persistență → <code class="ic">application/ports/</code> când un <em>use case</em> are nevoie; <code class="ic">domain/ports/</code> când un <em>domain service</em> are nevoie (D3). (Punerea unui port necesar domain-ului în <code class="ic">application/</code> ar forța domain-ul să importe application — o violare B1.) Astăzi doar <code class="ic">application/ports/</code> e folosit.</p>
    </div>
  </div>

  <div class="section" id="mappers">
    <h2 class="section-title"><span class="icon">🔀</span>4.6 Două tipuri distincte de mapper</h2>
    <div class="card">
      <div class="card-title">Infrastructure row mapper — <code class="ic">_row.mapper.ts</code></div>
      <p><strong>DB row → domain entity</strong> (rehidratare). Validează la intrare. Aruncă <code class="ic">PersistenceError</code> pe date corupte în DB, nu silențios o entitate greșită.</p>
    </div>
    <div class="card">
      <div class="card-title">Application response mapper — <code class="ic">application/mappers/*</code></div>
      <p><strong>Domain entity → response DTO</strong>. Returnează deseori un <code class="ic">Result</code> astfel încât un caz imposibil devine o eroare tipizată, nu un crash.</p>
    </div>
  </div>

  <div class="section" id="repos">
    <h2 class="section-title"><span class="icon">🗃️</span>4.7 Convenții repository — <span class="rule ok">D4</span>, <span class="rule err">B3</span></h2>
    <ul>
      <li><strong>Interfață:</strong> <code class="ic">I&lt;Thing&gt;Repository</code> în <code class="ic">domain/repository_interfaces/</code>, returnând <code class="ic">ResultAsync&lt;..., PersistenceError&gt;</code>, termeni de domain — <span class="rule err">fără <code class="ic">@prisma-client/*</code></span>.</li>
      <li><strong>Implementare:</strong> <code class="ic">&lt;Thing&gt;PrismaRepository</code> în <code class="ic">infrastructure/repositories/</code>, <code class="ic">@injectable()</code>, Prisma via <code class="ic">@inject("PrismaDeliveryClient")</code>, fiecare apel înfășurat în <code class="ic">ResultAsync.fromPromise(...)</code>, erorile DB cunoscute (<code class="ic">P2002</code>) traduse în erori de domain.</li>
    </ul>
    <div class="callout warn">
      <span class="rule err">B3</span>: interfața de repository a domain-ului trebuie să folosească termeni de domain. Interfața <code class="ic">payment_reconciliation</code> importă <code class="ic">@prisma-client</code> — aceasta e violarea concretă pentru care e modulul „cautionary".
    </div>
  </div>

  <div class="section" id="crossmod">
    <h2 class="section-title"><span class="icon">🚧</span>4.8 Granițe cross-module — <span class="rule err">B6</span>/D6 (contracte)</h2>
    <p>Un modul poate importa alt modul <strong>doar</strong> prin barrel-ul său <code class="ic">index.ts</code> sau prin <code class="ic">shared/contracts/**</code>. Accesul în <code class="ic">domain|application|infrastructure/**</code> al altui modul este scurgere (<span class="rule err">B6</span>).</p>
    <p>Comportamentul inter-module merge printr-un <strong>contract</strong>:</p>

    <div class="flow">
      <div class="flow-step">
        <div class="flow-num">1</div>
        <div class="flow-content">
          <div class="flow-label">Declară <code class="ic">shared/contracts/&lt;provider&gt;/&lt;x&gt;.contract.ts</code></div>
          <div class="flow-detail">Interfață pură — nicio implementare, nicio dependință de framework.</div>
        </div>
      </div>
      <div class="flow-step">
        <div class="flow-num">2</div>
        <div class="flow-content">
          <div class="flow-label">Providerul implementează în <code class="ic">infrastructure/adapters/&lt;x&gt;.contract.adapter.ts</code></div>
          <div class="flow-detail">Și înregistrează token-ul în propriul <code class="ic">di.config.ts</code>.</div>
        </div>
      </div>
      <div class="flow-step">
        <div class="flow-num">3</div>
        <div class="flow-content">
          <div class="flow-label">Consumatorul injectează token-ul contractului</div>
          <div class="flow-detail">Nu importă niciodată ceva din interiorul modulului provider.</div>
        </div>
      </div>
    </div>
  </div>

  <div class="section" id="purity">
    <h2 class="section-title"><span class="icon">🛡️</span>4.9 Puritatea domain-ului & allowlist-ul — <span class="rule err">B3</span></h2>
    <p>Domain-ul nu importă <strong>niciun path alias</strong> (<code class="ic">@server/*</code>, <code class="ic">@prisma-client/*</code>, <code class="ic">@helper/*</code>, …) — rămâne pur. Singura excepție: un <strong>utilitar pur auditat, fără efecte secundare</strong> pe <code class="ic">DOMAIN_PURE_UTIL_ALLOWLIST</code> din <code class="ic">ddd-lint</code> (seeded cu <code class="ic">@helper/date/date_utils</code>). Interdicția vizează efecte/IO/cuplare framework, nu funcții pure totale. <code class="ic">@logger</code>/<code class="ic">@config</code> sunt permise peste tot <em>în afara</em> domain-ului.</p>
  </div>

  <div class="section" id="uow">
    <h2 class="section-title"><span class="icon">⚛️</span>4.10 Unit of Work pentru tranzacții multi-repository</h2>
    <p>Când o operație trebuie să scrie prin mai multe repositories atomic, folosești un <strong>Unit of Work</strong> — un generic mic în shared kernel:</p>

    <div class="code-block">
      <div class="code-header"><span class="code-lang">TypeScript</span><span class="code-file">modules/shared/application/unit_of_work/unit_of_work.ts</span></div>
      <pre><code><span class="kw">export interface</span> <span class="ty">UnitOfWork</span>&lt;<span class="ty">ContextType</span>&gt; {
  <span class="fn">execute</span>&lt;<span class="ty">T</span>&gt;(work: (context: <span class="ty">ContextType</span>) => <span class="ty">Promise</span>&lt;<span class="ty">T</span>&gt;): <span class="ty">Promise</span>&lt;<span class="ty">T</span>&gt;;
}</code></pre>
    </div>
    <p>UoW-urile concrete (ex. <code class="ic">payment_reconciliation/infrastructure/unit_of_work/</code>) rulează <code class="ic">work</code> într-o singură <code class="ic">$transaction</code> Prisma. Module mai simple ca <code class="ic">feature_request</code> folosesc direct <code class="ic">prisma.$transaction</code> în interiorul unui singur repository.</p>
  </div>

  <div class="section" id="naming">
    <h2 class="section-title"><span class="icon">📝</span>4.11 Naming — <span class="rule err">N1</span>, D2</h2>
    <p><span class="rule err">N1</span>: fișiere <code class="ic">snake_case</code>, clase/tipuri <code class="ic">PascalCase</code>.</p>
    <table>
      <thead><tr><th>Concept</th><th>Convenție</th><th>Exemplu</th><th>Note / excepții</th></tr></thead>
      <tbody>
        <tr><td>Entity</td><td><code class="ic">&lt;Name&gt;Entity</code></td><td><code class="ic">FeatureRequestEntity</code></td><td><code class="ic">payments</code> folosește <code class="ic">PaymentMethod</code> (fără sufix; și counter-example D11)</td></tr>
        <tr><td>Value object</td><td>fișier <code class="ic">*.value_object.ts</code> (D2, preferat)</td><td><code class="ic">MoneyVO</code></td><td><code class="ic">.vo.ts</code> tolerat; D2 e soft/non-gated</td></tr>
        <tr><td>Use case</td><td><code class="ic">&lt;Action&gt;&lt;Thing&gt;UseCase</code>, un <code class="ic">execute()</code> (D1)</td><td><code class="ic">ToggleVoteUseCase</code></td><td><code class="ic">application/services/*Service</code> ca entry point e pattern pre-D1</td></tr>
        <tr><td>Repo interface</td><td><code class="ic">I&lt;Thing&gt;Repository</code></td><td><code class="ic">IFeatureVoteRepository</code></td><td>în <code class="ic">domain/repository_interfaces/</code></td></tr>
        <tr><td>Repo impl</td><td><code class="ic">&lt;Thing&gt;PrismaRepository</code></td><td><code class="ic">FeatureVotePrismaRepository</code></td><td>—</td></tr>
        <tr><td>Controller</td><td><code class="ic">&lt;Context&gt;Controller</code></td><td><code class="ic">FeatureRequestController</code></td><td>—</td></tr>
        <tr><td>Domain error</td><td><code class="ic">&lt;Reason&gt;Error</code>, returnat nu aruncat (E1)</td><td><code class="ic">CannotVoteOwnFeatureError</code></td><td><code class="ic">*.errors.ts</code> agregat OK (D10 eliminat)</td></tr>
      </tbody>
    </table>
  </div>

  <div class="section" id="shared">
    <h2 class="section-title"><span class="icon">🫙</span>4.12 Shared kernel (<code class="ic">modules/shared</code>)</h2>
    <p>Modelul comun mic, agreat, pe care orice modul îl poate folosi: value objects (<code class="ic">Money</code>, <code class="ic">EmailMessage</code>, …), entități partajate (<code class="ic">BackgroundTask</code>, <code class="ic">AppSetting</code>), application ports (<code class="ic">EmailSender</code>, <code class="ic">FileStorage</code>, <code class="ic">Queue</code>, …) + adaptori, baza <code class="ic">UnitOfWork</code>, logger-ul Winston, distributed locking, interfața <code class="ic">IApiErrorMapper</code> + helpere HTTP, tipuri de eroare comune, și <code class="ic">contracts/</code> (cusătura tipizată pentru apeluri cross-module). Înregistrat <strong>primul</strong> la boot.</p>
  </div>

  <!-- ══════════════════════════════════════════
       PART 5 — OPENAPI
  ══════════════════════════════════════════ -->

  <div class="section" id="openapi">
    <h2 class="section-title"><span class="icon">📐</span>Part 5 — Tipuri & Granița OpenAPI (<span class="rule err">T1</span>–<span class="rule warn">T3</span>)</h2>
    <p>Granița API e <strong>single-sourced</strong>. Un fișier JSON Schema per shape, sub <code class="ic">application/schemas/**/*.schema.json</code>, alimentează <em>atât</em>:</p>
    <ul>
      <li><strong>Validarea runtime</strong> via AJV (în controller), și</li>
      <li><strong>Tipurile compile-time</strong> via <code class="ic">openapi-typescript</code>, compuse în <code class="ic">shared/apis/public/coleteonline_web/openapi.json</code> și generate în <code class="ic">shared/apis/generated/coleteonline_web.generated.types.ts</code>.</li>
    </ul>

    <div class="flow">
      <div class="flow-step">
        <div class="flow-num">1</div>
        <div class="flow-content">
          <div class="flow-label">Scrii <code class="ic">*.request.schema.json</code> (sau <code class="ic">*.response.schema.json</code>)</div>
          <div class="flow-detail">Sursa de adevăr — o singură definiție.</div>
        </div>
      </div>
      <div class="flow-step">
        <div class="flow-num">2</div>
        <div class="flow-content">
          <div class="flow-label">Schema e referențiată în <code class="ic">openapi.json</code> via <code class="ic">$ref</code></div>
        </div>
      </div>
      <div class="flow-step">
        <div class="flow-num">3</div>
        <div class="flow-content">
          <div class="flow-label">Rulezi <code class="ic">openapi-typescript</code> → fișier generat de tipuri</div>
          <div class="flow-detail"><span class="rule warn">T3 WARN</span>: fă asta după orice editare de schema / openapi.json.</div>
        </div>
      </div>
      <div class="flow-step">
        <div class="flow-num">4</div>
        <div class="flow-content">
          <div class="flow-label">Controller-ul extrage tipurile din <code class="ic">paths[...]</code> în <code class="ic">*.types.ts</code> sibilin</div>
          <div class="flow-detail"><span class="rule warn">T2 WARN</span>: un request/response de controller care nu trece prin tipurile generate ar trebui migrat.</div>
        </div>
      </div>
    </div>

    <div class="code-block">
      <div class="code-header"><span class="code-lang">TypeScript</span><span class="code-file">infrastructure/controllers/feature_request.types.ts</span></div>
      <pre><code><span class="kw">type</span> <span class="ty">Route</span> = paths[<span class="str">"/feature-requests/{id}/vote"</span>];
<span class="kw">export type</span> <span class="ty">VoteResponse</span> = <span class="ty">Route</span>[<span class="str">"post"</span>][<span class="str">"responses"</span>][<span class="str">"200"</span>][<span class="str">"content"</span>][<span class="str">"application/json"</span>];</code></pre>
    </div>

    <div class="code-block">
      <div class="code-header"><span class="code-lang">bash</span><span class="code-file">Regenerare tipuri după editare schema</span></div>
      <pre><code>npx openapi-typescript \
  src/modules/shared/apis/public/coleteonline_web/openapi.json \
  -o src/modules/shared/apis/generated/coleteonline_web.generated.types.ts</code></pre>
    </div>

    <div class="callout warn">
      <strong><span class="rule err">T1 ERROR</span>:</strong> nu re-declara manual un shape care există deja ca schemă generată. Violator cunoscut: <code class="ic">payments/application/dto/payment_methods.response.dto.ts</code> duplică <code class="ic">payment_methods.response.schema</code>. <strong>Derivă din tipurile generate în schimb.</strong>
    </div>

    <p><strong>Beneficiul:</strong> body-ul pe care AJV îl validează, TypeScript-ul cu care compilează controller-ul și tipurile HTTP ale clientului sunt <strong>aceeași definiție</strong> — nu pot deriva.</p>
  </div>

  <!-- ══════════════════════════════════════════
       PART 6 — COMPLIANCE
  ══════════════════════════════════════════ -->

  <div class="section" id="linter">
    <h2 class="section-title"><span class="icon">🤖</span>6.1 Linter determinist — <code class="ic">npm run ddd:lint</code></h2>
    <p>Adăugat de PR #390 / COL-595. <code class="ic">server/scripts/ddd-lint/</code> (pur <code class="ic">tsx</code>, fără dependințe noi) analizează static graful de importuri și token-urile DI. E ground truth-ul pentru <span class="rule err">B1</span>/<span class="rule err">B2</span>/<span class="rule err">B3</span>/<span class="rule err">B6</span>/<span class="rule warn">B8</span>/<span class="rule err">D8</span>/<span class="rule err">DI1</span> — <em>rulează-l, nu ghici direcția importurilor cu ochii</em>:</p>

    <div class="code-block">
      <div class="code-header"><span class="code-lang">bash</span></div>
      <pre><code><span class="kw">cd</span> server

<span class="cmt"># Mod CI: eșuează DOAR pe erori NOI față de baseline.json</span>
npm run ddd:lint

<span class="cmt"># Audit complet per modul</span>
npm run ddd:lint -- --module feature_request

<span class="cmt"># Audit pe fișiere specifice (ex. after a PR)</span>
npm run ddd:lint -- --files <span class="str">"a.ts,b.ts"</span> --json

<span class="cmt"># Re-snapshotează baseline după ce ai reparat o datorie bazală</span>
npm run ddd:lint:baseline</code></pre>
    </div>

    <div class="callout tip">
      <code class="ic">baseline.json</code> îngheață <strong>42 de violări pre-existente</strong> astfel încât datoria existentă e <em>urmărită, nu blocantă</em>; CI eșuează doar pe violările pe care o ramură le introduce nou.
    </div>
  </div>

  <div class="section" id="skill">
    <h2 class="section-title"><span class="icon">🧑‍⚖️</span>6.2 Skill de judecată — <code class="ic">/ddd-review</code></h2>
    <p><code class="ic">.claude/skills/ddd-review/SKILL.md</code> citește <code class="ic">CONVENTIONS.md</code>, rulează linter-ul, apoi adaugă review-ul pe care scriptul nu îl poate face: duplicare de tip vs. OpenAPI generat (<span class="rule err">T1</span>), OpenAPI la boundary (<span class="rule warn">T2</span>/<span class="rule warn">T3</span>), construcția entității/VO (<span class="rule ok">D11</span>), cusătura de contract (<span class="rule err">B6</span>), și <span class="rule err">DI4</span> reachability (verificarea manuală cu valoare mare). Diff by default; audit complet când numești un modul.</p>
    <div class="code-block">
      <div class="code-header"><span class="code-lang">bash</span></div>
      <pre><code>/ddd-review                      <span class="cmt"># review pe diff-ul curent</span>
/ddd-review feature_request      <span class="cmt"># audit complet pe modul</span></code></pre>
    </div>
  </div>

  <div class="section" id="ruleref">
    <h2 class="section-title"><span class="icon">📋</span>6.3 Rule ID — referință rapidă</h2>
    <table>
      <thead><tr><th>ID</th><th>Sev.</th><th>Ce interzice / cere</th><th>Unde e explicat</th></tr></thead>
      <tbody>
        <tr><td class="mono">B1</td><td><span class="rule err">ERR</span></td><td>domain ⇏ application / infrastructure</td><td>§1.4, §2.3</td></tr>
        <tr><td class="mono">B2</td><td><span class="rule err">ERR</span></td><td>application ⇏ infrastructure</td><td>§1.4</td></tr>
        <tr><td class="mono">B3</td><td><span class="rule err">ERR</span></td><td>domain fără alias-uri / framework-uri (excepție: pure-util allowlist)</td><td>§4.9, §4.7</td></tr>
        <tr><td class="mono">B6</td><td><span class="rule err">ERR</span></td><td>cross-module doar via <code class="ic">index.ts</code> / <code class="ic">shared/contracts</code></td><td>§4.8</td></tr>
        <tr><td class="mono">B8</td><td><span class="rule warn">WARN</span></td><td>import din <code class="ic">@server/*</code> legacy = tech-debt</td><td>§2.1</td></tr>
        <tr><td class="mono">D8</td><td><span class="rule err">ERR</span></td><td>fără <code class="ic">tsyringe</code> în domain</td><td>§4.4</td></tr>
        <tr><td class="mono">DI1</td><td><span class="rule err">ERR</span></td><td>fiecare token injectat e înregistrat</td><td>§3.3, §4.4</td></tr>
        <tr><td class="mono">DI2</td><td><span class="rule warn">WARN</span></td><td>token-uri din <code class="ic">tokens.ts as const</code> (neadoptat)</td><td>§4.4</td></tr>
        <tr><td class="mono">DI3</td><td><span class="rule err">ERR</span></td><td>interfețe prin string token, clase self-bind</td><td>§3.3</td></tr>
        <tr><td class="mono">DI4</td><td><span class="rule err">ERR</span></td><td><code class="ic">di.config</code> reachable din fiecare entry point</td><td>§2.4</td></tr>
        <tr><td class="mono">T1</td><td><span class="rule err">ERR</span></td><td>nu duplica un shape generat din schema</td><td>§5</td></tr>
        <tr><td class="mono">T2/T3</td><td><span class="rule warn">WARN</span></td><td>tipuri generate OpenAPI la boundary; regenerează după edit</td><td>§5</td></tr>
        <tr><td class="mono">E1</td><td><span class="rule err">ERR</span></td><td><code class="ic">Result</code>/<code class="ic">ResultAsync</code>, fără <code class="ic">throw</code> pentru eșecuri așteptate</td><td>§4.1</td></tr>
        <tr><td class="mono">N1</td><td><span class="rule err">ERR</span></td><td>fișiere <code class="ic">snake_case</code>, tipuri <code class="ic">PascalCase</code></td><td>§4.11</td></tr>
      </tbody>
    </table>
  </div>

  <div class="section" id="decisions">
    <h2 class="section-title"><span class="icon">🏛️</span>6.4 Decisions log D1–D11 — fork-urile pe care spec-ul le-a rezolvat</h2>
    <p><code class="ic">CONVENTIONS.md §0</code> înregistrează fiecare loc unde codebase-ul se contrazicea pe sine și care parte a câștigat. Lista canonică, mereu actuală, e acolo — nu aici. Rezumat:</p>
    <table>
      <thead><tr><th>Decizie</th><th>Câștigătorul</th><th>Status</th></tr></thead>
      <tbody>
        <tr><td class="mono">D1</td><td>Use cases cu <code class="ic">execute()</code> în loc de application services ca entry point</td><td><span class="badge bd-ok">adoptat</span></td></tr>
        <tr><td class="mono">D2</td><td>Sufix <code class="ic">.value_object.ts</code> (soft, non-gated; <code class="ic">.vo.ts</code> tolerat)</td><td><span class="badge bd-ok">soft</span></td></tr>
        <tr><td class="mono">D3/D4</td><td>Port-urile deținute de layer-ul care declară nevoia</td><td><span class="badge bd-ok">adoptat</span></td></tr>
        <tr><td class="mono">D5</td><td>Barrel <code class="ic">index.ts</code> curat, niciodată <code class="ic">export *</code></td><td><span class="badge bd-ok">adoptat</span></td></tr>
        <tr><td class="mono">D6</td><td>Cross-module doar via contracte/barrel</td><td><span class="badge bd-ok">adoptat</span></td></tr>
        <tr><td class="mono">D7</td><td>Token-uri în <code class="ic">tokens.ts</code> (<code class="ic">as const</code>)</td><td><span class="badge bd-warn">neadoptat</span></td></tr>
        <tr><td class="mono">D8</td><td>Fără framework în domain</td><td><span class="badge bd-ok">adoptat</span></td></tr>
        <tr><td class="mono">D9</td><td><code class="ic">neverthrow</code></td><td><span class="badge bd-ok">adoptat</span></td></tr>
        <tr><td class="mono">D10</td><td>Un fișier per eroare — <strong>eliminat</strong>; <code class="ic">*.errors.ts</code> agregat OK</td><td><span class="badge bd-ok">eliminat</span></td></tr>
        <tr><td class="mono">D11</td><td>Entități cu ctor privat + factories statice</td><td><span class="badge bd-ok">adoptat</span></td></tr>
      </tbody>
    </table>
    <div class="callout tip">Orice decizie pe care nu o agreezi poate fi <strong>vetată</strong> — adaugă un comentariu în <code class="ic">CONVENTIONS.md §0</code> cu raționamentul tău.</div>
  </div>
</fezzan-page>
