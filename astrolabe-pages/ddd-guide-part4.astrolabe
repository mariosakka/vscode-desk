<fezzan-page title="DDD Part 7–8 + Appendix">
  <style>
    /* ═══════════════════════════════════════════════
       Study guide — shared base styles (fezzan port)
       Sidebar + body-flex layout removed; theme is fixed
       to the dark palette (no JS theme toggle in fezzan).
       ═══════════════════════════════════════════════ */
    
    :root {
      --bg: #0f1117;
      --surface: #1a1d27;
      --surface2: #22263a;
      --border: #2e3250;
      --accent: #7c6af7;
      --accent2: #5eead4;
      --text: #e2e8f0;
      --muted: #8892a4;
      --code-bg: #12141f;
      --tag-domain: #7c6af7;
      --tag-app: #5eead4;
      --tag-infra: #f59e0b;
      --tag-warn: #ef4444;
      --radius: 10px;
      --font-code: 'JetBrains Mono', 'Fira Code', 'Cascadia Code', monospace;
    }
    
    /* ── Main column (centered, no sidebar) ── */
    main {
      max-width: 900px;
      margin: 0 auto;
      padding: 24px 32px 96px;
      background: var(--bg);
      color: var(--text);
      font-family: 'Inter', 'Segoe UI', system-ui, sans-serif;
      font-size: 15px;
      line-height: 1.7;
    }
    
    /* ── Page header ── */
    .page-header {
      margin-bottom: 48px;
      padding-bottom: 32px;
      border-bottom: 1px solid var(--border);
    }
    .eyebrow {
      font-size: 11px;
      letter-spacing: .1em;
      text-transform: uppercase;
      color: var(--accent);
      margin-bottom: 10px;
      font-weight: 700;
    }
    .page-header h1 {
      font-size: 30px;
      font-weight: 700;
      line-height: 1.2;
      margin-bottom: 14px;
    }
    .page-header p { color: var(--muted); max-width: 620px; margin-bottom: 0; }
    
    /* ── Badges ── */
    .badge {
      display: inline-block;
      padding: 2px 9px;
      border-radius: 20px;
      font-size: 11px;
      font-weight: 700;
      letter-spacing: .04em;
      margin-right: 5px;
    }
    .bd-domain  { background: rgba(124,106,247,.16); color: var(--tag-domain); }
    .bd-app     { background: rgba(94,234,212,.14);  color: var(--tag-app); }
    .bd-infra   { background: rgba(245,158,11,.14);  color: var(--tag-infra); }
    .bd-warn    { background: rgba(239,68,68,.14);   color: var(--tag-warn); }
    .bd-ok      { background: rgba(34,197,94,.14);   color: #22c55e; }
    
    /* ── Section ── */
    .section { margin-bottom: 60px; scroll-margin-top: 24px; }
    
    h2.section-title {
      font-size: 20px;
      font-weight: 700;
      margin-bottom: 18px;
      display: flex;
      align-items: center;
      gap: 10px;
    }
    h2.section-title .icon {
      width: 30px; height: 30px;
      background: var(--surface2);
      border: 1px solid var(--border);
      border-radius: 7px;
      display: inline-flex;
      align-items: center;
      justify-content: center;
      font-size: 14px;
      flex-shrink: 0;
    }
    
    h3.sub { font-size: 14px; font-weight: 700; color: var(--accent2); text-transform: uppercase; letter-spacing: .08em; margin: 28px 0 12px; }
    
    p { color: var(--muted); margin-bottom: 12px; }
    p strong, li strong { color: var(--text); }
    ul, ol { padding-left: 20px; color: var(--muted); margin-bottom: 12px; }
    li { margin-bottom: 4px; }
    
    /* ── Cards ── */
    .card {
      background: var(--surface);
      border: 1px solid var(--border);
      border-radius: var(--radius);
      padding: 18px 22px;
      margin-bottom: 14px;
    }
    .card-title { font-size: 13px; font-weight: 700; color: var(--text); margin-bottom: 6px; }
    .card p { margin: 0; font-size: 13.5px; }
    
    /* ── Callouts ── */
    .callout {
      border-left: 3px solid var(--accent);
      background: rgba(124,106,247,.07);
      border-radius: 0 var(--radius) var(--radius) 0;
      padding: 13px 17px;
      margin: 14px 0;
      font-size: 13.5px;
      color: var(--muted);
    }
    .callout strong { color: var(--text); }
    .callout.tip  { border-color: var(--accent2); background: rgba(94,234,212,.06); }
    .callout.warn { border-color: var(--tag-warn); background: rgba(239,68,68,.06); }
    .callout.ok   { border-color: #22c55e; background: rgba(34,197,94,.06); }
    .callout.infra{ border-color: var(--tag-infra); background: rgba(245,158,11,.06); }
    
    /* ── Code blocks ── */
    .code-block {
      background: var(--code-bg);
      border: 1px solid var(--border);
      border-radius: var(--radius);
      margin: 14px 0;
      overflow: hidden;
    }
    .code-header {
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding: 9px 15px;
      border-bottom: 1px solid var(--border);
      background: var(--surface2);
      gap: 8px;
    }
    .code-lang { font-size: 10px; font-weight: 700; color: var(--accent); text-transform: uppercase; letter-spacing: .08em; flex-shrink: 0; }
    .code-file { font-size: 11px; color: var(--muted); font-family: var(--font-code); overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
    .copy-btn {
      background: none;
      border: 1px solid var(--border);
      border-radius: 5px;
      color: var(--muted);
      font-size: 11px;
      padding: 2px 9px;
      cursor: pointer;
      transition: all .15s;
      flex-shrink: 0;
    }
    .copy-btn:hover { color: var(--text); border-color: var(--accent); }
    .copy-btn.copied { color: var(--accent2); border-color: var(--accent2); }
    
    pre {
      padding: 16px 18px;
      overflow-x: auto;
      font-family: var(--font-code);
      font-size: 12.5px;
      line-height: 1.65;
      color: var(--text);
      scrollbar-width: thin;
      scrollbar-color: var(--border) transparent;
    }
    code { font-family: var(--font-code); }
    
    .ic {
      background: var(--code-bg);
      border: 1px solid var(--border);
      border-radius: 4px;
      padding: 1px 6px;
      font-family: var(--font-code);
      font-size: 12px;
      color: var(--accent2);
    }
    
    /* Syntax colours — dark */
    .kw   { color: #c792ea; }
    .fn   { color: #82aaff; }
    .str  { color: #c3e88d; }
    .num  { color: #f78c6c; }
    .cmt  { color: #546e7a; font-style: italic; }
    .ty   { color: #ffcb6b; }
    .prop { color: #89ddff; }
    .dec  { color: #ff5370; }
    
    /* ── Tables ── */
    table { width: 100%; border-collapse: collapse; margin: 14px 0; font-size: 13.5px; }
    th {
      background: var(--surface2);
      color: var(--muted);
      text-align: left;
      padding: 9px 13px;
      font-size: 10.5px;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: .06em;
      border-bottom: 1px solid var(--border);
    }
    td {
      padding: 10px 13px;
      border-bottom: 1px solid var(--border);
      color: var(--text);
      vertical-align: top;
    }
    tr:last-child td { border-bottom: none; }
    tr:hover td { background: rgba(255,255,255,.015); }
    td.mono { font-family: var(--font-code); font-size: 12px; color: var(--accent2); white-space: nowrap; }
    td.center { text-align: center; }
    
    /* ── Flow / step diagrams ── */
    .flow {
      background: var(--surface);
      border: 1px solid var(--border);
      border-radius: var(--radius);
      padding: 20px 22px;
      margin: 14px 0 20px;
    }
    .flow-step {
      display: flex;
      align-items: flex-start;
      gap: 13px;
      padding: 9px 0;
      border-bottom: 1px solid var(--border);
    }
    .flow-step:last-child { border-bottom: none; }
    .flow-num {
      width: 24px; height: 24px;
      background: var(--accent);
      color: #fff;
      border-radius: 50%;
      display: flex; align-items: center; justify-content: center;
      font-size: 10px; font-weight: 700;
      flex-shrink: 0; margin-top: 3px;
    }
    .flow-num.ret  { background: var(--accent2); color: var(--bg); }
    .flow-num.warn { background: var(--tag-warn); }
    .flow-num.infra{ background: var(--tag-infra); color: #0f1117; }
    .flow-content { flex: 1; min-width: 0; }
    .flow-label { font-size: 13px; color: var(--text); font-weight: 500; flex-wrap: wrap; }
    .flow-detail { font-size: 12px; color: var(--muted); margin-top: 3px; }
    .arr { color: var(--muted); margin: 0 4px; font-size: 11px; }
    
    /* ── Layer diagram ── */
    .layer-diagram { display: flex; flex-direction: column; gap: 4px; margin: 16px 0; }
    .layer {
      border-radius: 8px;
      padding: 12px 18px;
      display: flex;
      align-items: center;
      gap: 12px;
      font-size: 13px;
    }
    .layer.l-infra  { background: rgba(245,158,11,.1); border: 1px solid rgba(245,158,11,.3); }
    .layer.l-app    { background: rgba(94,234,212,.08); border: 1px solid rgba(94,234,212,.25); }
    .layer.l-domain { background: rgba(124,106,247,.1); border: 1px solid rgba(124,106,247,.3); }
    .layer .layer-name { font-weight: 700; font-size: 12px; min-width: 90px; }
    .layer.l-infra  .layer-name { color: var(--tag-infra); }
    .layer.l-app    .layer-name { color: var(--tag-app); }
    .layer.l-domain .layer-name { color: var(--tag-domain); }
    .layer .layer-items { color: var(--muted); font-size: 12.5px; }
    .layer .dep-arrow { margin-left: auto; font-size: 11px; color: var(--muted); white-space: nowrap; }
    
    /* ── Checklist ── */
    .checklist { list-style: none; margin: 14px 0; }
    .checklist li {
      display: flex;
      gap: 11px;
      padding: 9px 0;
      border-bottom: 1px solid var(--border);
      align-items: flex-start;
      font-size: 13.5px;
      color: var(--muted);
    }
    .checklist li:last-child { border-bottom: none; }
    .check-num {
      width: 22px; height: 22px;
      background: var(--surface2);
      border: 1px solid var(--border);
      border-radius: 50%;
      display: flex; align-items: center; justify-content: center;
      font-size: 10px; font-weight: 700;
      color: var(--accent);
      flex-shrink: 0; margin-top: 2px;
    }
    .checklist li strong { color: var(--text); }
    
    /* ── Collapsible ── */
    details {
      border: 1px solid var(--border);
      border-radius: var(--radius);
      margin-bottom: 10px;
      overflow: hidden;
    }
    summary {
      padding: 13px 17px;
      cursor: pointer;
      font-size: 13.5px;
      font-weight: 600;
      color: var(--text);
      background: var(--surface);
      list-style: none;
      display: flex;
      align-items: center;
      justify-content: space-between;
      user-select: none;
    }
    summary::-webkit-details-marker { display: none; }
    summary::after { content: '▸'; color: var(--muted); font-size: 11px; }
    details[open] summary::after { content: '▾'; }
    details[open] summary { border-bottom: 1px solid var(--border); }
    .details-body { padding: 16px 18px; background: var(--code-bg); }
    
    /* ── Rule pill ── */
    .rule {
      display: inline-block;
      font-family: var(--font-code);
      font-size: 10.5px;
      font-weight: 700;
      padding: 1px 7px;
      border-radius: 4px;
      margin: 0 2px;
    }
    .rule.err  { background: rgba(239,68,68,.14); color: var(--tag-warn); border: 1px solid rgba(239,68,68,.3); }
    .rule.warn { background: rgba(245,158,11,.14); color: var(--tag-infra); border: 1px solid rgba(245,158,11,.3); }
    .rule.ok   { background: rgba(34,197,94,.12); color: #22c55e; border: 1px solid rgba(34,197,94,.25); }
    
    /* ── Scrollbar ── */
    ::-webkit-scrollbar { width: 6px; height: 6px; }
    ::-webkit-scrollbar-track { background: transparent; }
    ::-webkit-scrollbar-thumb { background: var(--border); border-radius: 3px; }
  </style>

  <div class="page-header">
    <div class="eyebrow">Part 7–8 + Appendix</div>
    <h1>Cheat-sheet, Glosar & Inventar</h1>
    <p>Pași concreți pentru a adăuga lucruri „în felul nostru", glosarul complet DDD termen → nume repo → fișier, și o radiografie a celor 10 bounded contexts.</p>
  </div>

  <!-- ══════════════════════════════════════════
       PART 7 — CHEAT-SHEET
  ══════════════════════════════════════════ -->

  <div class="section" id="new-usecase">
    <h2 class="section-title"><span class="icon">➕</span>7.1 Adaugă un use case nou la un modul existent</h2>

    <ul class="checklist">
      <li>
        <div class="check-num">1</div>
        <div>
          <strong>Domain primul.</strong> Regulă/stare nouă → adaugă la entitate/VO (+ un <code class="ic">.error.ts</code> dacă poate eșua).<br/>
          <span style="font-size:12.5px;color:var(--muted)">Ține domain-ul fără framework (<span class="rule err">B1</span>/<span class="rule err">B3</span>/<span class="rule err">D8</span>).</span>
        </div>
      </li>
      <li>
        <div class="check-num">2</div>
        <div>
          <strong>Interfață repository.</strong> Acces nou la date → adaugă o metodă la <code class="ic">I&lt;Thing&gt;Repository</code> (<code class="ic">ResultAsync&lt;..., PersistenceError&gt;</code>, termeni de domain — <span class="rule err">B3</span>); implementează în <code class="ic">PrismaRepository</code>.
        </div>
      </li>
      <li>
        <div class="check-num">3</div>
        <div>
          <strong>Use case.</strong> <code class="ic">application/use_cases/&lt;action&gt;_&lt;thing&gt;.use_case.ts</code>, <code class="ic">@injectable()</code>, un singur <code class="ic">execute()</code> care returnează <code class="ic">ResultAsync&lt;Succes, ErrorUnion&gt;</code> (<span class="rule ok">D1</span>). Injectează interfețe prin string token. <strong>Fără SQL aici</strong> (<span class="rule err">B2</span>).
        </div>
      </li>
      <li>
        <div class="check-num">4</div>
        <div>
          <strong>Înregistrează</strong> în <code class="ic">di.config.ts</code> (<span class="rule err">DI1</span>/<span class="rule err">DI3</span>).
        </div>
      </li>
      <li>
        <div class="check-num">5</div>
        <div>
          <strong>Controller.</strong> Validează input (AJV), apelează <code class="ic">execute()</code>, pe <code class="ic">isErr()</code> rutează la error mapper. Tipizează boundary-ul din tipurile OpenAPI generate (<span class="rule warn">T2</span>).
        </div>
      </li>
      <li>
        <div class="check-num">6</div>
        <div>
          <strong>Error mapper.</strong> Mapează orice eroare de domain nouă → HTTP status (<span class="rule err">E1</span> → RFC-7807).
        </div>
      </li>
      <li>
        <div class="check-num">7</div>
        <div>
          <strong>Rută.</strong> <code class="ic">router.&lt;verb&gt;("/...", (req,res,next) => container.resolve(Controller).method(req,res,next))</code>.
        </div>
      </li>
      <li>
        <div class="check-num">8</div>
        <div>
          <strong>Verifică.</strong>
          <div class="code-block" style="margin-top:8px">
            <div class="code-header"><span class="code-lang">bash</span></div>
            <pre><code>cd server && npm run ddd:lint -- --files &lt;fișiere_schimbate&gt;
<span class="cmt"># sau</span>
/ddd-review</code></pre>
          </div>
        </div>
      </li>
    </ul>
  </div>

  <div class="section" id="new-module">
    <h2 class="section-title"><span class="icon">🏗️</span>7.2 Adaugă un modul nou (bounded context)</h2>

    <ul class="checklist">
      <li>
        <div class="check-num">1</div>
        <div>
          <strong>Crează scheletul</strong> <code class="ic">domain/ application/ infrastructure/</code> (§2.3) + <code class="ic">di.config.ts</code> + un <code class="ic">index.ts</code> subțire, curat (<span class="rule ok">D5</span>).
        </div>
      </li>
      <li>
        <div class="check-num">2</div>
        <div>
          <strong>În <code class="ic">server/src/server.ts</code>:</strong> adaugă side-effect import (după <code class="ic">shared</code>) și <code class="ic">app.use(...)</code> pentru rute. Confirmă reachability <span class="rule err">DI4</span> pentru fiecare entry point care îl montează.
          <div class="code-block" style="margin-top:8px">
            <div class="code-header"><span class="code-lang">TypeScript</span></div>
            <pre><code><span class="kw">import</span> <span class="str">"./modules/my_new_module/di.config"</span>;
<span class="cmt">// ...</span>
app.<span class="fn">use</span>(<span class="str">"/my-resource"</span>, auth.<span class="fn">authorize</span>(), myNewModuleRoutes);</code></pre>
          </div>
        </div>
      </li>
      <li>
        <div class="check-num">3</div>
        <div>
          <strong>Nevoile cross-module</strong> merg prin <code class="ic">shared/contracts/**</code> (<span class="rule err">B6</span>), nu import-uri adânci.
        </div>
      </li>
      <li>
        <div class="check-num">4</div>
        <div>
          <strong>Rulează <code class="ic">/ddd-review &lt;modul&gt;</code></strong> — țintă <strong>0 erori noi</strong> (modulul <code class="ic">tickets</code> a mers 21 → 0 în acest fel).
        </div>
      </li>
    </ul>
  </div>

  <!-- ══════════════════════════════════════════
       PART 8 — GLOSSARY
  ══════════════════════════════════════════ -->

  <div class="section" id="glossary">
    <h2 class="section-title"><span class="icon">📖</span>Part 8 — Glosar (termen DDD → nume repo → fișier)</h2>
    <table>
      <thead><tr><th>Termen DDD</th><th>În acest repo</th><th>Fișier reprezentativ</th></tr></thead>
      <tbody>
        <tr>
          <td>Bounded context</td>
          <td>un folder de modul</td>
          <td class="mono">server/src/modules/feature_request/</td>
        </tr>
        <tr>
          <td>Entity</td>
          <td><code class="ic">*Entity</code>, ctor privat + factories (<span class="rule ok">D11</span>)</td>
          <td class="mono">domain/entities/feature_request.entity.ts</td>
        </tr>
        <tr>
          <td>Value Object</td>
          <td><code class="ic">*VO</code> / fișier <code class="ic">*.value_object.ts</code> (<span class="rule warn">D2</span>)</td>
          <td class="mono">domain/value_objects/vote_weight.vo.ts</td>
        </tr>
        <tr>
          <td>Repository (interfață)</td>
          <td><code class="ic">I*Repository</code> în domain, <code class="ic">ResultAsync</code> (<span class="rule ok">D4</span>)</td>
          <td class="mono">domain/repository_interfaces/feature_vote.repository.interface.ts</td>
        </tr>
        <tr>
          <td>Repository (impl)</td>
          <td><code class="ic">*PrismaRepository</code> în infrastructure</td>
          <td class="mono">infrastructure/repositories/feature_vote.prisma.repository.ts</td>
        </tr>
        <tr>
          <td>Application service / Use Case</td>
          <td><code class="ic">*UseCase</code> cu <code class="ic">execute()</code> (<span class="rule ok">D1</span>)</td>
          <td class="mono">application/use_cases/toggle_vote.use_case.ts</td>
        </tr>
        <tr>
          <td>Domain Service</td>
          <td><code class="ic">*Service</code> stateless, <strong>fără <code class="ic">@injectable</code></strong> (<span class="rule err">D8</span>)</td>
          <td class="mono">modules/shipping_point_widget/domain/services/point_thinner.service.ts</td>
        </tr>
        <tr>
          <td>Port (outbound)</td>
          <td>interfață <code class="ic">I*</code> în <code class="ic">application/ports/</code> (sau <code class="ic">domain/ports/</code>, <span class="rule ok">D3</span>)</td>
          <td class="mono">application/ports/feature_request_notifier.port.ts</td>
        </tr>
        <tr>
          <td>Adapter</td>
          <td><code class="ic">*Adapter</code> în <code class="ic">infrastructure/adapters/</code></td>
          <td class="mono">infrastructure/adapters/email_feature_request_notifier.adapter.ts</td>
        </tr>
        <tr>
          <td>Factory</td>
          <td><code class="ic">static create()</code> / <code class="ic">fromPrimitive()</code></td>
          <td class="mono">domain/entities/feature_request.entity.ts:52-80</td>
        </tr>
        <tr>
          <td>Domain Error</td>
          <td>clasă <code class="ic">*Error</code>, returnată nu aruncată (<span class="rule err">E1</span>)</td>
          <td class="mono">domain/errors/feature_request.errors.ts</td>
        </tr>
        <tr>
          <td>Result / Either</td>
          <td><code class="ic">neverthrow</code> <code class="ic">Result</code> / <code class="ic">ResultAsync</code></td>
          <td>folosit peste tot</td>
        </tr>
        <tr>
          <td>Composition root</td>
          <td><code class="ic">di.config.ts</code> per modul</td>
          <td class="mono">feature_request/di.config.ts</td>
        </tr>
        <tr>
          <td>Cross-module contract</td>
          <td><code class="ic">shared/contracts/**</code> + <code class="ic">*.contract.adapter.ts</code> (<span class="rule err">B6</span>)</td>
          <td class="mono">modules/shared/contracts/**</td>
        </tr>
        <tr>
          <td>Shared kernel</td>
          <td><code class="ic">modules/shared</code></td>
          <td class="mono">modules/shared/**</td>
        </tr>
        <tr>
          <td>Unit of Work</td>
          <td><code class="ic">UnitOfWork&lt;Ctx&gt;</code></td>
          <td class="mono">modules/shared/application/unit_of_work/unit_of_work.ts</td>
        </tr>
        <tr>
          <td>Spec + linter + skill</td>
          <td><code class="ic">CONVENTIONS.md</code> + <code class="ic">/ddd-review</code> + <code class="ic">npm run ddd:lint</code></td>
          <td class="mono">.claude/skills/ddd-review/ &amp; server/scripts/ddd-lint/</td>
        </tr>
      </tbody>
    </table>
  </div>

  <!-- ══════════════════════════════════════════
       APPENDIX
  ══════════════════════════════════════════ -->

  <div class="section" id="inventory">
    <h2 class="section-title"><span class="icon">📦</span>Appendix — Inventar module</h2>
    <p>Tot DDD-ul trăiește sub <code class="ic">server/src/modules/</code>. Nouă module folosesc layering DDD complet; <code class="ic">analytics</code> e infrastructure-only; <code class="ic">shared</code> e kernelul.</p>

    <table>
      <thead><tr><th>Modul</th><th>Bounded context</th><th>Adâncime</th><th>Note</th></tr></thead>
      <tbody>
        <tr>
          <td class="mono">feature_request</td>
          <td>Panou de idei — submit / vot / workflow admin</td>
          <td><span class="badge bd-ok">Bogat</span></td>
          <td>✅ modul de referință (cel mai curat)</td>
        </tr>
        <tr>
          <td class="mono">payments</td>
          <td>Metode plată, eligibilitate, carduri salvate, rambursări</td>
          <td><span class="badge bd-ok">Bogat</span></td>
          <td><code class="ic">@injectable</code> în domain services (<span class="rule err">D8</span>); DTO duplică schemă (<span class="rule err">T1</span>)</td>
        </tr>
        <tr>
          <td class="mono">payment_reconciliation</td>
          <td>Potrivire extrase bancare cu plăți din sistem</td>
          <td><span class="badge bd-ok">Bogat</span></td>
