<fezzan-page title="DDD + Backend Guide">
  <style>
    /* ═══════════════════════════════════════════════
       Study guide — shared base styles (fezzan port)
       Sidebar + body-flex layout removed; theme is fixed
       to the dark palette (no JS theme toggle in fezzan).
       ═══════════════════════════════════════════════ */
    
    :root {
      --bg: #0f1117;
      --surface: #1a1d27;
      --surface2: #22263a;
      --border: #2e3250;
      --accent: #7c6af7;
      --accent2: #5eead4;
      --text: #e2e8f0;
      --muted: #8892a4;
      --code-bg: #12141f;
      --tag-domain: #7c6af7;
      --tag-app: #5eead4;
      --tag-infra: #f59e0b;
      --tag-warn: #ef4444;
      --radius: 10px;
      --font-code: 'JetBrains Mono', 'Fira Code', 'Cascadia Code', monospace;
    }
    
    /* ── Main column (centered, no sidebar) ── */
    main {
      max-width: 900px;
      margin: 0 auto;
      padding: 24px 32px 96px;
      background: var(--bg);
      color: var(--text);
      font-family: 'Inter', 'Segoe UI', system-ui, sans-serif;
      font-size: 15px;
      line-height: 1.7;
    }
    
    /* ── Page header ── */
    .page-header {
      margin-bottom: 48px;
      padding-bottom: 32px;
      border-bottom: 1px solid var(--border);
    }
    .eyebrow {
      font-size: 11px;
      letter-spacing: .1em;
      text-transform: uppercase;
      color: var(--accent);
      margin-bottom: 10px;
      font-weight: 700;
    }
    .page-header h1 {
      font-size: 30px;
      font-weight: 700;
      line-height: 1.2;
      margin-bottom: 14px;
    }
    .page-header p { color: var(--muted); max-width: 620px; margin-bottom: 0; }
    
    /* ── Badges ── */
    .badge {
      display: inline-block;
      padding: 2px 9px;
      border-radius: 20px;
      font-size: 11px;
      font-weight: 700;
      letter-spacing: .04em;
      margin-right: 5px;
    }
    .bd-domain  { background: rgba(124,106,247,.16); color: var(--tag-domain); }
    .bd-app     { background: rgba(94,234,212,.14);  color: var(--tag-app); }
    .bd-infra   { background: rgba(245,158,11,.14);  color: var(--tag-infra); }
    .bd-warn    { background: rgba(239,68,68,.14);   color: var(--tag-warn); }
    .bd-ok      { background: rgba(34,197,94,.14);   color: #22c55e; }
    
    /* ── Section ── */
    .section { margin-bottom: 60px; scroll-margin-top: 24px; }
    
    h2.section-title {
      font-size: 20px;
      font-weight: 700;
      margin-bottom: 18px;
      display: flex;
      align-items: center;
      gap: 10px;
    }
    h2.section-title .icon {
      width: 30px; height: 30px;
      background: var(--surface2);
      border: 1px solid var(--border);
      border-radius: 7px;
      display: inline-flex;
      align-items: center;
      justify-content: center;
      font-size: 14px;
      flex-shrink: 0;
    }
    
    h3.sub { font-size: 14px; font-weight: 700; color: var(--accent2); text-transform: uppercase; letter-spacing: .08em; margin: 28px 0 12px; }
    
    p { color: var(--muted); margin-bottom: 12px; }
    p strong, li strong { color: var(--text); }
    ul, ol { padding-left: 20px; color: var(--muted); margin-bottom: 12px; }
    li { margin-bottom: 4px; }
    
    /* ── Cards ── */
    .card {
      background: var(--surface);
      border: 1px solid var(--border);
      border-radius: var(--radius);
      padding: 18px 22px;
      margin-bottom: 14px;
    }
    .card-title { font-size: 13px; font-weight: 700; color: var(--text); margin-bottom: 6px; }
    .card p { margin: 0; font-size: 13.5px; }
    
    /* ── Callouts ── */
    .callout {
      border-left: 3px solid var(--accent);
      background: rgba(124,106,247,.07);
      border-radius: 0 var(--radius) var(--radius) 0;
      padding: 13px 17px;
      margin: 14px 0;
      font-size: 13.5px;
      color: var(--muted);
    }
    .callout strong { color: var(--text); }
    .callout.tip  { border-color: var(--accent2); background: rgba(94,234,212,.06); }
    .callout.warn { border-color: var(--tag-warn); background: rgba(239,68,68,.06); }
    .callout.ok   { border-color: #22c55e; background: rgba(34,197,94,.06); }
    .callout.infra{ border-color: var(--tag-infra); background: rgba(245,158,11,.06); }
    
    /* ── Code blocks ── */
    .code-block {
      background: var(--code-bg);
      border: 1px solid var(--border);
      border-radius: var(--radius);
      margin: 14px 0;
      overflow: hidden;
    }
    .code-header {
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding: 9px 15px;
      border-bottom: 1px solid var(--border);
      background: var(--surface2);
      gap: 8px;
    }
    .code-lang { font-size: 10px; font-weight: 700; color: var(--accent); text-transform: uppercase; letter-spacing: .08em; flex-shrink: 0; }
    .code-file { font-size: 11px; color: var(--muted); font-family: var(--font-code); overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
    .copy-btn {
      background: none;
      border: 1px solid var(--border);
      border-radius: 5px;
      color: var(--muted);
      font-size: 11px;
      padding: 2px 9px;
      cursor: pointer;
      transition: all .15s;
      flex-shrink: 0;
    }
    .copy-btn:hover { color: var(--text); border-color: var(--accent); }
    .copy-btn.copied { color: var(--accent2); border-color: var(--accent2); }
    
    pre {
      padding: 16px 18px;
      overflow-x: auto;
      font-family: var(--font-code);
      font-size: 12.5px;
      line-height: 1.65;
      color: var(--text);
      scrollbar-width: thin;
      scrollbar-color: var(--border) transparent;
    }
    code { font-family: var(--font-code); }
    
    .ic {
      background: var(--code-bg);
      border: 1px solid var(--border);
      border-radius: 4px;
      padding: 1px 6px;
      font-family: var(--font-code);
      font-size: 12px;
      color: var(--accent2);
    }
    
    /* Syntax colours — dark */
    .kw   { color: #c792ea; }
    .fn   { color: #82aaff; }
    .str  { color: #c3e88d; }
    .num  { color: #f78c6c; }
    .cmt  { color: #546e7a; font-style: italic; }
    .ty   { color: #ffcb6b; }
    .prop { color: #89ddff; }
    .dec  { color: #ff5370; }
    
    /* ── Tables ── */
    table { width: 100%; border-collapse: collapse; margin: 14px 0; font-size: 13.5px; }
    th {
      background: var(--surface2);
      color: var(--muted);
      text-align: left;
      padding: 9px 13px;
      font-size: 10.5px;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: .06em;
      border-bottom: 1px solid var(--border);
    }
    td {
      padding: 10px 13px;
      border-bottom: 1px solid var(--border);
      color: var(--text);
      vertical-align: top;
    }
    tr:last-child td { border-bottom: none; }
    tr:hover td { background: rgba(255,255,255,.015); }
    td.mono { font-family: var(--font-code); font-size: 12px; color: var(--accent2); white-space: nowrap; }
    td.center { text-align: center; }
    
    /* ── Flow / step diagrams ── */
    .flow {
      background: var(--surface);
      border: 1px solid var(--border);
      border-radius: var(--radius);
      padding: 20px 22px;
      margin: 14px 0 20px;
    }
    .flow-step {
      display: flex;
      align-items: flex-start;
      gap: 13px;
      padding: 9px 0;
      border-bottom: 1px solid var(--border);
    }
    .flow-step:last-child { border-bottom: none; }
    .flow-num {
      width: 24px; height: 24px;
      background: var(--accent);
      color: #fff;
      border-radius: 50%;
      display: flex; align-items: center; justify-content: center;
      font-size: 10px; font-weight: 700;
      flex-shrink: 0; margin-top: 3px;
    }
    .flow-num.ret  { background: var(--accent2); color: var(--bg); }
    .flow-num.warn { background: var(--tag-warn); }
    .flow-num.infra{ background: var(--tag-infra); color: #0f1117; }
    .flow-content { flex: 1; min-width: 0; }
    .flow-label { font-size: 13px; color: var(--text); font-weight: 500; flex-wrap: wrap; }
    .flow-detail { font-size: 12px; color: var(--muted); margin-top: 3px; }
    .arr { color: var(--muted); margin: 0 4px; font-size: 11px; }
    
    /* ── Layer diagram ── */
    .layer-diagram { display: flex; flex-direction: column; gap: 4px; margin: 16px 0; }
    .layer {
      border-radius: 8px;
      padding: 12px 18px;
      display: flex;
      align-items: center;
      gap: 12px;
      font-size: 13px;
    }
    .layer.l-infra  { background: rgba(245,158,11,.1); border: 1px solid rgba(245,158,11,.3); }
    .layer.l-app    { background: rgba(94,234,212,.08); border: 1px solid rgba(94,234,212,.25); }
    .layer.l-domain { background: rgba(124,106,247,.1); border: 1px solid rgba(124,106,247,.3); }
    .layer .layer-name { font-weight: 700; font-size: 12px; min-width: 90px; }
    .layer.l-infra  .layer-name { color: var(--tag-infra); }
    .layer.l-app    .layer-name { color: var(--tag-app); }
    .layer.l-domain .layer-name { color: var(--tag-domain); }
    .layer .layer-items { color: var(--muted); font-size: 12.5px; }
    .layer .dep-arrow { margin-left: auto; font-size: 11px; color: var(--muted); white-space: nowrap; }
    
    /* ── Checklist ── */
    .checklist { list-style: none; margin: 14px 0; }
    .checklist li {
      display: flex;
      gap: 11px;
      padding: 9px 0;
      border-bottom: 1px solid var(--border);
      align-items: flex-start;
      font-size: 13.5px;
      color: var(--muted);
    }
    .checklist li:last-child { border-bottom: none; }
    .check-num {
      width: 22px; height: 22px;
      background: var(--surface2);
      border: 1px solid var(--border);
      border-radius: 50%;
      display: flex; align-items: center; justify-content: center;
      font-size: 10px; font-weight: 700;
      color: var(--accent);
      flex-shrink: 0; margin-top: 2px;
    }
    .checklist li strong { color: var(--text); }
    
    /* ── Collapsible ── */
    details {
      border: 1px solid var(--border);
      border-radius: var(--radius);
      margin-bottom: 10px;
      overflow: hidden;
    }
    summary {
      padding: 13px 17px;
      cursor: pointer;
      font-size: 13.5px;
      font-weight: 600;
      color: var(--text);
      background: var(--surface);
      list-style: none;
      display: flex;
      align-items: center;
      justify-content: space-between;
      user-select: none;
    }
    summary::-webkit-details-marker { display: none; }
    summary::after { content: '▸'; color: var(--muted); font-size: 11px; }
    details[open] summary::after { content: '▾'; }
    details[open] summary { border-bottom: 1px solid var(--border); }
    .details-body { padding: 16px 18px; background: var(--code-bg); }
    
    /* ── Rule pill ── */
    .rule {
      display: inline-block;
      font-family: var(--font-code);
      font-size: 10.5px;
      font-weight: 700;
      padding: 1px 7px;
      border-radius: 4px;
      margin: 0 2px;
    }
    .rule.err  { background: rgba(239,68,68,.14); color: var(--tag-warn); border: 1px solid rgba(239,68,68,.3); }
    .rule.warn { background: rgba(245,158,11,.14); color: var(--tag-infra); border: 1px solid rgba(245,158,11,.3); }
    .rule.ok   { background: rgba(34,197,94,.12); color: #22c55e; border: 1px solid rgba(34,197,94,.25); }
    
    /* ── Scrollbar ── */
    ::-webkit-scrollbar { width: 6px; height: 6px; }
    ::-webkit-scrollbar-track { background: transparent; }
    ::-webkit-scrollbar-thumb { background: var(--border); border-radius: 3px; }
    
    /* ── Page-specific (index hub) ── */
    .hub-grid {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(340px, 1fr));
      gap: 14px;
      margin-top: 28px;
    }
    .hub-card {
      background: var(--surface);
      border: 1px solid var(--border);
      border-radius: var(--radius);
      padding: 22px 24px;
      text-decoration: none;
      color: var(--text);
      display: flex;
      flex-direction: column;
      gap: 8px;
      transition: all .15s;
    }
    .hub-card:hover { border-color: var(--accent); transform: translateY(-1px); }
    .hub-card .hc-eyebrow { font-size: 10px; font-weight: 700; text-transform: uppercase; letter-spacing: .1em; color: var(--muted); }
    .hub-card h3 { font-size: 16px; font-weight: 700; color: var(--text); }
    .hub-card p { font-size: 13px; color: var(--muted); margin: 0; }
    .hub-card .hc-tags { display: flex; gap: 6px; flex-wrap: wrap; margin-top: 4px; }
    .hub-card .hc-arrow { margin-top: auto; padding-top: 10px; font-size: 18px; color: var(--accent); }
    
    .source-box {
      background: var(--surface);
      border: 1px solid var(--border);
      border-radius: var(--radius);
      padding: 18px 22px;
      margin-top: 32px;
      display: flex;
      gap: 16px;
      align-items: flex-start;
    }
    .source-box .sb-icon { font-size: 22px; flex-shrink: 0; margin-top: 2px; }
    .source-box h3 { font-size: 14px; font-weight: 700; margin-bottom: 6px; }
    .source-box p { font-size: 13px; color: var(--muted); margin: 0; }
  </style>

  <div class="page-header">
    <div class="eyebrow">Backend — colete-online.ro</div>
    <h1>DDD + Backend Guide</h1>
    <p>Un ghid practic: ce este DDD în general și cum îl aplicăm concret în <code class="ic">server/src/modules/</code>. Destinat oricărui inginer care vrea să citească, să extindă sau să revizuiască codul de backend cu încredere.</p>
    <br/>
    <span class="badge bd-domain">Domain</span>
    <span class="badge bd-app">Application</span>
    <span class="badge bd-infra">Infrastructure</span>
  </div>

  <!-- Source of truth callout -->
  <div class="source-box">
    <div class="sb-icon">📍</div>
    <div>
      <h3>Sursa de adevăr normativă</h3>
      <p>Spec-ul opinionat pentru <code class="ic">server/src/modules/**</code> este <code class="ic">.claude/skills/ddd-review/CONVENTIONS.md</code> (adăugat prin PR #390 / COL-595). El definește layerele, rule ID-urile (<code class="ic">B1</code>–<code class="ic">B8</code>, <code class="ic">D1</code>–<code class="ic">D11</code>, <code class="ic">DI1</code>–<code class="ic">DI4</code>, <code class="ic">T1</code>–<code class="ic">T3</code>, <code class="ic">E1</code>, <code class="ic">N1</code>) și un decisions log. <strong>Când cele două documente se contrazic, CONVENTIONS.md câștigă.</strong> Acest ghid citează ID-urile de reguli ca să poți sări între ele.</p>
    </div>
  </div>

  <div class="hub-grid">

    <span class="hub-card">
      <div class="hc-eyebrow">Part 1</div>
      <h3>DDD în general</h3>
      <p>Ce este DDD, de ce există, building blocks tactice, arhitecturi, exemple în 5 limbaje, DDD pe toate tipurile de app, testare, trade-offs.</p>
      <div class="hc-tags">
        <span class="badge bd-domain">Portabil</span>
        <span class="badge bd-app">Teorie</span>
      </div>
      <div class="hc-arrow">→</div>
    </span>

    <span class="hub-card">
      <div class="hc-eyebrow">Part 2–3</div>
      <h3>Proiect & Exemplu complet</h3>
      <p>Cum e cablat DDD în repo: structura modulului, bootstrap DI, routing Express. Exemplu <code class="ic">feature_request</code> urmărit end-to-end de la vote la răspuns HTTP.</p>
      <div class="hc-tags">
        <span class="badge bd-domain">Domain</span>
        <span class="badge bd-app">Application</span>
        <span class="badge bd-infra">Infrastructure</span>
      </div>
      <div class="hc-arrow">→</div>
    </span>

    <span class="hub-card">
      <div class="hc-eyebrow">Part 4–6</div>
      <h3>House style, tipuri & tooling</h3>
      <p>Regulile noastre concrete: neverthrow, tsyringe, ports vs events, naming, OpenAPI boundary, linter <code class="ic">npm run ddd:lint</code>, skill <code class="ic">/ddd-review</code>.</p>
      <div class="hc-tags">
        <span class="badge bd-warn">Reguli</span>
        <span class="badge bd-infra">Tooling</span>
      </div>
      <div class="hc-arrow">→</div>
    </span>

    <span class="hub-card">
      <div class="hc-eyebrow">Part 7–8 + Appendix</div>
      <h3>Cheat-sheet & Glosar</h3>
      <p>Cum adaugi un use case nou sau un modul nou pas cu pas. Glosar complet DDD termen → nume repo → fișier. Inventar module (10 bounded contexts).</p>
      <div class="hc-tags">
        <span class="badge bd-ok">Referință</span>
      </div>
      <div class="hc-arrow">→</div>
    </span>

  </div>

  <!-- Quick rule ref -->
  <div class="section" style="margin-top:56px;">
    <h2 class="section-title"><span class="icon">⚡</span>Rule ID-uri — referință rapidă</h2>
    <table>
      <thead><tr><th>ID</th><th>Severitate</th><th>Ce interzice / cere</th></tr></thead>
      <tbody>
        <tr><td class="mono">B1</td><td><span class="rule err">ERROR</span></td><td>domain ⇏ application / infrastructure</td></tr>
        <tr><td class="mono">B2</td><td><span class="rule err">ERROR</span></td><td>application ⇏ infrastructure</td></tr>
        <tr><td class="mono">B3</td><td><span class="rule err">ERROR</span></td><td>domain fără alias-uri / framework-uri (excepție: pure-util allowlist)</td></tr>
        <tr><td class="mono">B6</td><td><span class="rule err">ERROR</span></td><td>cross-module doar prin <code class="ic">index.ts</code> / <code class="ic">shared/contracts</code></td></tr>
        <tr><td class="mono">B8</td><td><span class="rule warn">WARN</span></td><td>import din <code class="ic">@server/*</code> legacy = tech-debt</td></tr>
        <tr><td class="mono">D8</td><td><span class="rule err">ERROR</span></td><td>fără <code class="ic">@injectable</code> în domain</td></tr>
        <tr><td class="mono">DI1</td><td><span class="rule err">ERROR</span></td><td>fiecare token injectat trebuie înregistrat în <code class="ic">di.config.ts</code></td></tr>
        <tr><td class="mono">DI2</td><td><span class="rule warn">WARN</span></td><td>token-urile în <code class="ic">tokens.ts as const</code> (neadoptat încă)</td></tr>
        <tr><td class="mono">DI3</td><td><span class="rule err">ERROR</span></td><td>interfețe → string token; clase → self-bind</td></tr>
        <tr><td class="mono">DI4</td><td><span class="rule err">ERROR</span></td><td><code class="ic">di.config</code> reachable din fiecare entry point</td></tr>
        <tr><td class="mono">T1</td><td><span class="rule err">ERROR</span></td><td>nu re-declara manual un shape deja generat din schema</td></tr>
        <tr><td class="mono">T2/T3</td><td><span class="rule warn">WARN</span></td><td>folosește tipurile generate OpenAPI la boundary; regenerează după edit</td></tr>
        <tr><td class="mono">E1</td><td><span class="rule err">ERROR</span></td><td><code class="ic">Result</code> / <code class="ic">ResultAsync</code> — fără <code class="ic">throw</code> pentru eșecuri așteptate</td></tr>
        <tr><td class="mono">N1</td><td><span class="rule err">ERROR</span></td><td>fișiere <code class="ic">snake_case</code>, tipuri <code class="ic">PascalCase</code></td></tr>
      </tbody>
    </table>
  </div>

</fezzan-page>
