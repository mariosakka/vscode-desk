{
  "name": "vscode-astrolabe",
  "displayName": "Astrolabe",
  "description": "Your developer portal — tabbed bookmarks with an embedded MCP server",
  "version": "1.0.0",
  "publisher": "mmswflow",
  "icon": "media/astrolabe.png",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/mariosakka/vscode-astrolabe.git"
  },
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "astrolabe",
          "title": "Astrolabe",
          "icon": "media/icon.svg"
        }
      ]
    },
    "views": {
      "astrolabe": [
        {
          "type": "webview",
          "id": "astrolabe.sidebar",
          "name": "Astrolabe"
        }
      ]
    },
    "commands": [
      {
        "command": "astrolabe.addBookmark",
        "title": "Astrolabe: Add Bookmark"
      },
      {
        "command": "astrolabe.addProject",
        "title": "Astrolabe: Add Project"
      },
      {
        "command": "astrolabe.removeBookmark",
        "title": "Astrolabe: Remove Bookmark"
      },
      {
        "command": "astrolabe.removeProject",
        "title": "Astrolabe: Remove Project"
      },
      {
        "command": "astrolabe.openPage",
        "title": "Astrolabe: Open Page"
      },
      {
        "command": "astrolabe.newPage",
        "title": "Astrolabe: New Page"
      },
      {
        "command": "astrolabe.setupAgents",
        "title": "Astrolabe: Set Up Agent MCP Integration"
      },
      {
        "command": "astrolabe.configureWorkflow",
        "title": "Astrolabe: Configure Workflow"
      },
      {
        "command": "astrolabe.installWorkflowSkills",
        "title": "Astrolabe: Install Workflow Skills"
      },
      {
        "command": "astrolabe.openUrl",
        "title": "Astrolabe: Open URL"
      },
      {
        "command": "astrolabe.updateBookmark",
        "title": "Astrolabe: Edit Bookmark"
      },
      {
        "command": "astrolabe.deletePage",
        "title": "Astrolabe: Delete Page"
      },
      {
        "command": "astrolabe.removeSkill",
        "title": "Astrolabe: Remove Skill"
      },
      {
        "command": "astrolabe.newSkill",
        "title": "Astrolabe: New Skill"
      },
      {
        "command": "astrolabe.editSkill",
        "title": "Astrolabe: Edit Skill"
      },
      {
        "command": "astrolabe.submitSkill",
        "title": "Astrolabe: Submit Skill"
      },
      {
        "command": "astrolabe.listProjects",
        "title": "Astrolabe: List Projects"
      },
      {
        "command": "astrolabe.listBookmarks",
        "title": "Astrolabe: List Bookmarks"
      },
      {
        "command": "astrolabe.listSkills",
        "title": "Astrolabe: List Skills"
      },
      {
        "command": "astrolabe.viewWorkflow",
        "title": "Astrolabe: View Workflow Config"
      }
    ],
    "configuration": {
      "title": "Astrolabe",
      "properties": {
        "astrolabe.mcpPort": {
          "type": "number",
          "default": 3333,
          "description": "Port for the embedded MCP HTTP server"
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "npm run compile:ext && npm run compile:webview",
    "compile:ext": "webpack --config webpack.config.js --mode production",
    "compile:webview": "webpack --config webpack.webview.config.js --mode production",
    "watch": "webpack --config webpack.config.js --mode development --watch",
    "watch:webview": "webpack --config webpack.webview.config.js --mode development --watch",
    "test": "jest",
    "test:e2e": "playwright test",
    "test:e2e:install": "playwright install --with-deps chromium",
    "package": "vsce package"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.0",
    "@types/jest": "^29.5.0",
    "@types/node": "^20.0.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@types/vscode": "^1.85.0",
    "@vscode/vsce": "^3.0.0",
    "copy-webpack-plugin": "^12.0.0",
    "css-loader": "^7.1.0",
    "jest": "^29.5.0",
    "mini-css-extract-plugin": "^2.9.0",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "ts-jest": "^29.1.0",
    "ts-loader": "^9.5.0",
    "typescript": "^5.3.0",
    "webpack": "^5.90.0",
    "webpack-cli": "^5.1.0"
  },
  "dependencies": {
    "lucide-react": "^1.21.0"
  }
}
