{
  "name": "vscode-relay",
  "displayName": "Relay",
  "description": "Your developer relay — tabbed bookmarks with an embedded MCP server",
  "version": "1.0.0",
  "publisher": "mmswflow",
  "icon": "media/relay.png",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/mariosakka/vscode-relay.git"
  },
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "relay",
          "title": "Relay",
          "icon": "media/icon.svg"
        }
      ]
    },
    "views": {
      "relay": [
        {
          "type": "webview",
          "id": "relay.sidebar",
          "name": "Relay"
        }
      ]
    },
    "commands": [
      {
        "command": "relay.addBookmark",
        "title": "Relay: Add Bookmark"
      },
      {
        "command": "relay.addTab",
        "title": "Relay: Add Tab"
      },
      {
        "command": "relay.removeBookmark",
        "title": "Relay: Remove Bookmark"
      },
      {
        "command": "relay.removeTab",
        "title": "Relay: Remove Tab"
      },
      {
        "command": "relay.openPage",
        "title": "Relay: Open Page"
      },
      {
        "command": "relay.newPage",
        "title": "Relay: New Page"
      }
    ],
    "configuration": {
      "title": "Relay",
      "properties": {
        "relay.mcpPort": {
          "type": "number",
          "default": 3333,
          "description": "Port for the embedded MCP HTTP server"
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "webpack --mode production",
    "watch": "webpack --mode development --watch",
    "test": "jest",
    "test:e2e": "playwright test",
    "test:e2e:install": "playwright install --with-deps chromium",
    "package": "vsce package"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.0",
    "@types/jest": "^29.5.0",
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.85.0",
    "@vscode/vsce": "^3.0.0",
    "copy-webpack-plugin": "^12.0.0",
    "jest": "^29.5.0",
    "ts-jest": "^29.1.0",
    "ts-loader": "^9.5.0",
    "typescript": "^5.3.0",
    "webpack": "^5.90.0",
    "webpack-cli": "^5.1.0"
  }
}
