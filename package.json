{
  "name": "vscode-desk",
  "displayName": "Desk",
  "description": "Tabbed bookmarks with favicons, a built-in lightweight document viewer, an embedded MCP server for AI agents, and a team workflow skill manager — all in your sidebar.",
  "version": "0.13.3",
  "publisher": "mariosakka",
  "icon": "media/lamp.png",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/mariosakka/vscode-desk.git"
  },
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "desk",
          "title": "Desk",
          "icon": "media/lamp.svg"
        }
      ]
    },
    "views": {
      "desk": [
        {
          "type": "webview",
          "id": "desk.sidebar",
          "name": "Desk"
        }
      ]
    },
    "commands": [
      {
        "command": "desk.addBookmark",
        "title": "Desk: Add Bookmark"
      },
      {
        "command": "desk.removeBookmark",
        "title": "Desk: Remove Bookmark"
      },
      {
        "command": "desk.openPage",
        "title": "Desk: Open Page"
      },
      {
        "command": "desk.newPage",
        "title": "Desk: New Page"
      },
      {
        "command": "desk.setupAgents",
        "title": "Desk: Set Up Agent MCP Integration"
      },
      {
        "command": "desk.configureWorkflow",
        "title": "Desk: Configure Workflow"
      },
      {
        "command": "desk.installWorkflowSkills",
        "title": "Desk: Install Workflow Skills"
      },
      {
        "command": "desk.openUrl",
        "title": "Desk: Open URL"
      },
      {
        "command": "desk.updateBookmark",
        "title": "Desk: Edit Bookmark"
      },
      {
        "command": "desk.deletePage",
        "title": "Desk: Delete Page"
      },
      {
        "command": "desk.removeSkill",
        "title": "Desk: Remove Skill"
      },
      {
        "command": "desk.newSkill",
        "title": "Desk: New Skill"
      },
      {
        "command": "desk.editSkill",
        "title": "Desk: Edit Skill"
      },
      {
        "command": "desk.submitSkill",
        "title": "Desk: Submit Skill"
      },
      {
        "command": "desk.listBookmarks",
        "title": "Desk: List Bookmarks"
      },
      {
        "command": "desk.listSkills",
        "title": "Desk: List Skills"
      },
      {
        "command": "desk.viewWorkflow",
        "title": "Desk: View Workflow Config"
      },
      {
        "command": "desk.newBook",
        "title": "Desk: New Book"
      },
      {
        "command": "desk.openBook",
        "title": "Desk: Open Book"
      },
      {
        "command": "desk.deleteBook",
        "title": "Desk: Delete Book"
      },
      {
        "command": "desk.addChapter",
        "title": "Desk: Add Chapter"
      },
      {
        "command": "desk.renameChapter",
        "title": "Desk: Rename Chapter"
      },
      {
        "command": "desk.removeChapter",
        "title": "Desk: Remove Chapter"
      },
      {
        "command": "desk.newBookPage",
        "title": "Desk: New Book Page"
      },
      {
        "command": "desk.moveBookPage",
        "title": "Desk: Move Book Page"
      },
      {
        "command": "desk.zoomIn",
        "title": "Desk: Zoom In"
      },
      {
        "command": "desk.zoomOut",
        "title": "Desk: Zoom Out"
      },
      {
        "command": "desk.zoomReset",
        "title": "Desk: Reset Zoom"
      },
      {
        "command": "desk.toggleToc",
        "title": "Desk: Toggle Page Sidebar"
      }
    ],
    "configuration": {
      "title": "Desk",
      "properties": {
        "desk.mcpPort": {
          "type": "number",
          "default": 3333,
          "description": "Port for the embedded MCP HTTP server"
        },
        "desk.pageViewer.defaultZoom": {
          "type": "number",
          "default": 100,
          "description": "Initial zoom percentage when no persisted zoom exists (50–300)."
        },
        "desk.pageViewer.tocCollapsed": {
          "type": "boolean",
          "default": true,
          "description": "Whether the TOC/book sidebar starts collapsed when opening a page."
        },
        "desk.pageViewer.openLinksIn": {
          "type": "string",
          "enum": [
            "simpleBrowser",
            "externalBrowser"
          ],
          "default": "simpleBrowser",
          "description": "Where external links in pages open: VS Code Simple Browser or the system browser."
        },
        "desk.pageViewer.singleTab": {
          "type": "boolean",
          "default": false,
          "description": "Navigate .desk links in the same tab instead of opening new tabs."
        },
        "desk.skillTools.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Expose skill-defined MCP tools via the Desk MCP server."
        },
        "desk.skillTools.timeoutSeconds": {
          "type": "number",
          "default": 30,
          "description": "Execution timeout in seconds for skill-defined MCP tool commands."
        },
        "desk.worktreeLinking.enabled": {
          "type": "boolean",
          "default": true,
          "description": "When true, a VS Code window opened on a linked git worktree resolves to the same Desk workspace as the main checkout."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "npm run compile:ext && npm run compile:webview",
    "compile:ext": "webpack --config webpack.config.js --mode production",
    "compile:webview": "webpack --config webpack.webview.config.js --mode production",
    "watch": "webpack --config webpack.config.js --mode development --watch",
    "watch:webview": "webpack --config webpack.webview.config.js --mode development --watch",
    "test": "jest",
    "test:e2e": "playwright test",
    "test:e2e:install": "playwright install --with-deps chromium",
    "package": "vsce package"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.0",
    "@types/jest": "^29.5.0",
    "@types/node": "^20.0.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@types/vscode": "^1.85.0",
    "@vscode/vsce": "^3.0.0",
    "copy-webpack-plugin": "^12.0.0",
    "css-loader": "^7.1.0",
    "jest": "^29.5.0",
    "mini-css-extract-plugin": "^2.9.0",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "ts-jest": "^29.1.0",
    "ts-loader": "^9.5.0",
    "typescript": "^5.3.0",
    "webpack": "^5.90.0",
    "webpack-cli": "^5.1.0"
  },
  "dependencies": {
    "lucide-react": "^1.21.0"
  }
}
