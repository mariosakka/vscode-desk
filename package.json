{
  "name": "vscode-fezzan",
  "displayName": "Fezzan",
  "description": "Your developer portal — tabbed bookmarks with an embedded MCP server",
  "version": "1.0.0",
  "publisher": "mmswflow",
  "icon": "media/relay.png",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/mariosakka/vscode-fezzan.git"
  },
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "fezzan",
          "title": "Fezzan",
          "icon": "media/icon.svg"
        }
      ]
    },
    "views": {
      "fezzan": [
        {
          "type": "webview",
          "id": "fezzan.sidebar",
          "name": "Fezzan"
        }
      ]
    },
    "commands": [
      {
        "command": "fezzan.addBookmark",
        "title": "Fezzan: Add Bookmark"
      },
      {
        "command": "fezzan.addTab",
        "title": "Fezzan: Add Tab"
      },
      {
        "command": "fezzan.removeBookmark",
        "title": "Fezzan: Remove Bookmark"
      },
      {
        "command": "fezzan.removeTab",
        "title": "Fezzan: Remove Tab"
      },
      {
        "command": "fezzan.openPage",
        "title": "Fezzan: Open Page"
      },
      {
        "command": "fezzan.newPage",
        "title": "Fezzan: New Page"
      },
      {
        "command": "fezzan.setupAgents",
        "title": "Fezzan: Set Up Agent MCP Integration"
      },
      {
        "command": "fezzan.configureWorkflow",
        "title": "Fezzan: Configure Workflow"
      },
      {
        "command": "fezzan.installWorkflowSkills",
        "title": "Fezzan: Install Workflow Skills"
      }
    ],
    "configuration": {
      "title": "Fezzan",
      "properties": {
        "fezzan.mcpPort": {
          "type": "number",
          "default": 3333,
          "description": "Port for the embedded MCP HTTP server"
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "npm run compile:ext && npm run compile:webview",
    "compile:ext": "webpack --config webpack.config.js --mode production",
    "compile:webview": "webpack --config webpack.webview.config.js --mode production",
    "watch": "webpack --config webpack.config.js --mode development --watch",
    "watch:webview": "webpack --config webpack.webview.config.js --mode development --watch",
    "test": "jest",
    "test:e2e": "playwright test",
    "test:e2e:install": "playwright install --with-deps chromium",
    "package": "vsce package"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.0",
    "@types/jest": "^29.5.0",
    "@types/node": "^20.0.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@types/vscode": "^1.85.0",
    "@vscode/vsce": "^3.0.0",
    "copy-webpack-plugin": "^12.0.0",
    "css-loader": "^7.1.0",
    "jest": "^29.5.0",
    "mini-css-extract-plugin": "^2.9.0",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "ts-jest": "^29.1.0",
    "ts-loader": "^9.5.0",
    "typescript": "^5.3.0",
    "webpack": "^5.90.0",
    "webpack-cli": "^5.1.0"
  }
}
