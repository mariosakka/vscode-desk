{
  "name": "vscode-relay",
  "displayName": "Relay",
  "description": "Your developer relay — tabbed bookmarks with an embedded MCP server",
  "version": "0.0.1",
  "publisher": "mmswflow",
  "icon": "media/relay.png",
  "engines": { "vscode": "^1.85.0" },
  "categories": ["Other"],
  "activationEvents": ["onStartupFinished"],
  "main": "./out/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [{
        "id": "relay",
        "title": "Relay",
        "icon": "media/icon.svg"
      }]
    },
    "views": {
      "relay": [{
        "type": "webview",
        "id": "relay.sidebar",
        "name": "Relay"
      }]
    },
    "commands": [
      { "command": "relay.addBookmark",    "title": "Relay: Add Bookmark" },
      { "command": "relay.addTab",         "title": "Relay: Add Tab" },
      { "command": "relay.removeBookmark", "title": "Relay: Remove Bookmark" },
      { "command": "relay.removeTab",      "title": "Relay: Remove Tab" }
    ],
    "configuration": {
      "title": "Relay",
      "properties": {
        "relay.mcpPort": {
          "type": "number",
          "default": 3333,
          "description": "Port for the embedded MCP HTTP server"
        }
      }
    }
  },
  "scripts": {
    "compile": "webpack --mode production",
    "watch": "webpack --mode development --watch",
    "test": "jest"
  },
  "devDependencies": {
    "@types/jest": "^29.5.0",
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.85.0",
    "copy-webpack-plugin": "^12.0.0",
    "jest": "^29.5.0",
    "ts-jest": "^29.1.0",
    "ts-loader": "^9.5.0",
    "typescript": "^5.3.0",
    "webpack": "^5.90.0",
    "webpack-cli": "^5.1.0"
  }
}
